---
import favorites from '../../scripts/recommendations/favorites.json';
import metadata from '../../scripts/recommendations/data/metadata.json';

interface Rec {
	title: string;
	subtitle: string;
	url: string;
	cover: string;
}

type Favorite = string | {
	url: string;
	cover?: string;
};

// Merge the hand-edited favorites list with scraped title/cover metadata.
const mergeByUrl = (items: Favorite[], meta: Rec[]): Rec[] => {
	const metaMap = new Map(meta.map(m => [m.url, m]));
	return items.map((item) => {
		const favorite = typeof item === 'string' ? { url: item } : item;
		const rec = metaMap.get(favorite.url);
		return rec ? { ...rec, cover: favorite.cover || rec.cover } : undefined;
	}).filter((rec): rec is Rec => Boolean(rec));
};

const films = mergeByUrl(favorites.films, metadata.films);
const books = mergeByUrl(favorites.books, metadata.books);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Favorites — Noah Eisen</title>
		<meta name="description" content="Noah Eisen's favorite films and books." />
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300;1,9..40,400&display=swap" rel="stylesheet" />
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-DW532NM54T"></script>
		<script>
			interface Window {
				dataLayer: any[];
				gtag: (...args: any[]) => void;
			}
			window.dataLayer = window.dataLayer || [];
			window.gtag = function() { window.dataLayer.push(arguments); };
			window.gtag('js', new Date());
			window.gtag('config', 'G-DW532NM54T');
		</script>
		<style>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			html, body { height: 100%; }
			body {
				background: #0a0a0a;
				font-family: 'DM Sans', sans-serif;
				color: #e2dfd8;
				-webkit-font-smoothing: antialiased;
			}

			.wrap {
				max-width: 920px;
				margin: 0 auto;
				padding: 52px 44px 80px;
			}

			/* === HEADER === */
			.back-link {
				font-size: 11px;
				color: #666;
				text-decoration: none;
				letter-spacing: 1px;
				text-transform: uppercase;
				display: inline-flex;
				align-items: center;
				gap: 8px;
				margin-bottom: 28px;
				transition: color 0.15s;
			}

			.back-link:hover { color: #999; }

			.page-title {
				font-size: 48px;
				font-weight: 700;
				letter-spacing: -1.5px;
				margin: 0 0 10px;
				color: #eae7e0;
				line-height: 1;
			}

			.page-desc {
				font-size: 14px;
				color: #777;
				margin: 0;
				line-height: 1.7;
				max-width: 520px;
			}

			/* === SECTION === */
			.section-label {
				font-size: 10px;
				letter-spacing: 4px;
				text-transform: uppercase;
				color: #444;
				display: block;
				margin-top: 52px;
				margin-bottom: 20px;
				padding-bottom: 16px;
				border-bottom: 1px solid #1a1a1a;
			}

			.favorites-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, 154px);
				gap: 22px 18px;
			}

			.favorite-link {
				color: inherit;
				text-decoration: none;
				display: block;
			}

			.favorite-link:hover .rec-cover,
			.favorite-link:focus-visible .rec-cover {
				border-color: #3a3a3a;
				transform: translateY(-2px);
			}

			.rec-cover {
				width: 100%;
				aspect-ratio: 2 / 3;
				border-radius: 4px;
				object-fit: cover;
				background: #151515;
				border: 1px solid #1e1e1e;
				display: block;
				transition: border-color 0.15s, transform 0.15s;
			}

			.rec-body {
				margin-top: 10px;
			}

			.rec-title {
				font-size: 14px;
				font-weight: 600;
				color: #e2dfd8;
				line-height: 1.25;
				margin-bottom: 4px;
			}

			.rec-subtitle {
				font-size: 11px;
				color: #555;
				line-height: 1.35;
			}

			/* === RESPONSIVE === */
			@media (max-width: 768px) {
				.wrap { padding: 36px 24px 60px; }
				.page-title { font-size: 36px; }
				.favorites-grid { grid-template-columns: repeat(auto-fill, 112px); }
			}
		</style>
	</head>
	<body>
		<main class="wrap">
			<div>
				<a href="/" class="back-link">&larr; Back to Noah Eisen</a>
				<h1 class="page-title">Favorites</h1>
				<p class="page-desc">Some of my favorite movies and books, in no particular order.</p>
			</div>

			<span class="section-label">Movies</span>

			<div class="favorites-grid">
				{films.map((film) => (
					<a class="favorite-link" href={film.url} target="_blank" rel="noopener noreferrer">
						<article>
							<img class="rec-cover" src={film.cover} alt={`${film.title} poster`} />
							<div class="rec-body">
								<div class="rec-title">{film.title}</div>
								<div class="rec-subtitle">{film.subtitle}</div>
							</div>
						</article>
					</a>
				))}
			</div>

			<span class="section-label">Books</span>

			<div class="favorites-grid">
				{books.map((book) => (
					<a class="favorite-link" href={book.url} target="_blank" rel="noopener noreferrer">
						<article>
							<img class="rec-cover" src={book.cover} alt={`${book.title} cover`} />
							<div class="rec-body">
								<div class="rec-title">{book.title}</div>
								<div class="rec-subtitle">{book.subtitle}</div>
							</div>
						</article>
					</a>
				))}
			</div>
		</main>
	</body>
</html>
