---
import reviews from '../../scripts/recommendations/reviews.json';
import metadata from '../../scripts/recommendations/data/metadata.json';

interface Rec {
	title: string;
	subtitle: string;
	url: string;
	review: string;
	cover: string;
}

// Merge: reviews from reviews.json (easy to edit), titles/covers from metadata.json (scraped)
const mergeByUrl = (revs: {url: string; review: string}[], meta: Omit<Rec, 'review'>[]): Rec[] => {
	const metaMap = new Map(meta.map(m => [m.url, m]));
	return revs.map(r => ({ ...metaMap.get(r.url)!, review: r.review }));
};

const films = mergeByUrl(reviews.films, metadata.films);
const books = mergeByUrl(reviews.books, metadata.books);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Favorites — Noah Eisen</title>
		<meta name="description" content="Noah Eisen's favorite films and books." />
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300;1,9..40,400&display=swap" rel="stylesheet" />
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-DW532NM54T"></script>
		<script>
			interface Window {
				dataLayer: any[];
				gtag: (...args: any[]) => void;
			}
			window.dataLayer = window.dataLayer || [];
			window.gtag = function() { window.dataLayer.push(arguments); };
			window.gtag('js', new Date());
			window.gtag('config', 'G-DW532NM54T');
		</script>
		<style>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			html, body { height: 100%; }
			body {
				background: #0a0a0a;
				font-family: 'DM Sans', sans-serif;
				color: #e2dfd8;
				-webkit-font-smoothing: antialiased;
			}

			.wrap {
				max-width: 920px;
				margin: 0 auto;
				padding: 52px 44px 80px;
			}

			/* === HEADER === */
			.back-link {
				font-size: 11px;
				color: #666;
				text-decoration: none;
				letter-spacing: 1px;
				text-transform: uppercase;
				display: inline-flex;
				align-items: center;
				gap: 8px;
				margin-bottom: 28px;
				transition: color 0.15s;
			}

			.back-link:hover { color: #999; }

			.page-title {
				font-size: 48px;
				font-weight: 700;
				letter-spacing: -1.5px;
				margin: 0 0 10px;
				color: #eae7e0;
				line-height: 1;
			}

			.page-desc {
				font-size: 14px;
				color: #777;
				margin: 0;
				line-height: 1.7;
				max-width: 520px;
			}

			/* === SECTION === */
			.section-label {
				font-size: 10px;
				letter-spacing: 4px;
				text-transform: uppercase;
				color: #444;
				display: block;
				margin-top: 52px;
				margin-bottom: 28px;
				padding-bottom: 16px;
				border-bottom: 1px solid #1a1a1a;
			}

			/* === RECOMMENDATION ENTRIES === */
			.rec-entry {
				display: grid;
				grid-template-columns: 120px 1fr;
				gap: 28px;
				padding: 28px 0;
				border-top: 1px solid #181818;
			}

			.rec-cover {
				width: 120px;
				height: 180px;
				border-radius: 4px;
				object-fit: cover;
				background: #151515;
				border: 1px solid #1e1e1e;
			}

			.rec-body {
				display: flex;
				flex-direction: column;
				justify-content: center;
			}

			.rec-badge {
				font-size: 9px;
				letter-spacing: 2px;
				font-weight: 600;
				padding: 2px 7px;
				border-radius: 3px;
				display: inline-block;
				margin-bottom: 12px;
				width: fit-content;
			}

			.rec-badge.film {
				color: #5b8ef0;
				border: 1px solid rgba(91, 142, 240, 0.25);
			}

			.rec-badge.book {
				color: #d4a84b;
				border: 1px solid rgba(212, 168, 75, 0.25);
			}

			.rec-title {
				font-size: 19px;
				font-weight: 600;
				color: #e2dfd8;
				line-height: 1.3;
				margin-bottom: 4px;
			}

			.rec-subtitle {
				font-size: 12px;
				color: #555;
				margin-bottom: 14px;
			}

			.rec-text {
				font-size: 13px;
				color: #888;
				line-height: 1.75;
				max-width: 580px;
			}

			/* === RESPONSIVE === */
			@media (max-width: 768px) {
				.wrap { padding: 36px 24px 60px; }
				.page-title { font-size: 36px; }

				.rec-entry {
					grid-template-columns: 84px 1fr;
					gap: 16px;
				}

				.rec-cover {
					width: 84px;
					height: 126px;
				}

				.rec-title { font-size: 16px; }
			}
		</style>
	</head>
	<body>
		<main class="wrap">
			<div>
				<a href="/" class="back-link">&larr; Back to Noah Eisen</a>
				<h1 class="page-title">Favorites</h1>
				<p class="page-desc">Films and books I think are exceptional and worth your time.</p>
			</div>

			<span class="section-label">Films</span>

			{films.map((film) => (
				<article class="rec-entry">
					<img class="rec-cover" src={film.cover} alt={`${film.title} poster`} />
					<div class="rec-body">
						<span class="rec-badge film">FILM</span>
						<div class="rec-title">{film.title}</div>
						<div class="rec-subtitle">{film.subtitle}</div>
						<p class="rec-text">{film.review}</p>
					</div>
				</article>
			))}

			<span class="section-label">Books</span>

			{books.map((book) => (
				<article class="rec-entry">
					<img class="rec-cover" src={book.cover} alt={`${book.title} cover`} />
					<div class="rec-body">
						<span class="rec-badge book">BOOK</span>
						<div class="rec-title">{book.title}</div>
						<div class="rec-subtitle">{book.subtitle}</div>
						<p class="rec-text">{book.review}</p>
					</div>
				</article>
			))}
		</main>
	</body>
</html>
