---
import favorites from '../../scripts/recommendations/favorites.json';
import metadata from '../../scripts/recommendations/data/metadata.json';

interface Rec {
	title: string;
	subtitle: string;
	url: string;
	cover: string;
}

type Favorite = string | {
	url: string;
	title?: string;
	subtitle?: string;
	cover?: string;
};

type FavoriteKind = 'films' | 'books';
type Viewport = 'desktop' | 'mobile';

interface FavoritesConfig {
	films: Favorite[];
	books: Favorite[];
	orders?: Partial<Record<Viewport, Partial<Record<FavoriteKind, string[]>>>>;
}

const favoritesConfig = favorites as FavoritesConfig;

const normalizeFavorite = (item: Favorite): Favorite & { url: string } => (
	typeof item === 'string' ? { url: item } : item
);

// Merge the hand-edited favorites list and optional viewport ordering with scraped metadata.
const resolveFavorites = (kind: FavoriteKind, viewport: Viewport, meta: Rec[]): Rec[] => {
	const items = favoritesConfig[kind];
	const favoriteMap = new Map(items.map((item) => {
		const favorite = normalizeFavorite(item);
		return [favorite.url, favorite];
	}));
	const metaMap = new Map(meta.map(m => [m.url, m]));
	const order = favoritesConfig.orders?.[viewport]?.[kind];
	const orderedFavorites = order
		? order.map((url) => favoriteMap.get(url) || { url })
		: items.map(normalizeFavorite);

	return orderedFavorites.map((favorite) => {
		const rec = metaMap.get(favorite.url);
		const resolved = {
			title: favorite.title || rec?.title || '',
			subtitle: favorite.subtitle || rec?.subtitle || '',
			url: favorite.url,
			cover: favorite.cover || rec?.cover || '',
		};

		return resolved.title && resolved.cover ? resolved : undefined;
	}).filter((rec): rec is Rec => Boolean(rec));
};

const desktopFilms = resolveFavorites('films', 'desktop', metadata.films);
const mobileFilms = resolveFavorites('films', 'mobile', metadata.films);
const desktopBooks = resolveFavorites('books', 'desktop', metadata.books);
const mobileBooks = resolveFavorites('books', 'mobile', metadata.books);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Favorites — Noah Eisen</title>
		<meta name="description" content="Noah Eisen's favorite films and books." />
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300;1,9..40,400&display=swap" rel="stylesheet" />
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-DW532NM54T"></script>
		<script>
			interface Window {
				dataLayer: any[];
				gtag: (...args: any[]) => void;
			}
			window.dataLayer = window.dataLayer || [];
			window.gtag = function() { window.dataLayer.push(arguments); };
			window.gtag('js', new Date());
			window.gtag('config', 'G-DW532NM54T');
		</script>
		<style>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			html, body { height: 100%; }
			body {
				background: #0a0a0a;
				font-family: 'DM Sans', sans-serif;
				color: #e2dfd8;
				-webkit-font-smoothing: antialiased;
			}

			.wrap {
				max-width: 920px;
				margin: 0 auto;
				padding: 52px 44px 80px;
			}

			/* === HEADER === */
			.back-link {
				font-size: 11px;
				color: #666;
				text-decoration: none;
				letter-spacing: 1px;
				text-transform: uppercase;
				display: inline-flex;
				align-items: center;
				gap: 8px;
				margin-bottom: 28px;
				transition: color 0.15s;
			}

			.back-link:hover { color: #999; }

			.page-title {
				font-size: 48px;
				font-weight: 700;
				letter-spacing: -1.5px;
				margin: 0 0 10px;
				color: #eae7e0;
				line-height: 1;
			}

			.page-desc {
				font-size: 14px;
				color: #777;
				margin: 0;
				line-height: 1.7;
				max-width: 520px;
			}

			/* === SECTION === */
			.section-label {
				font-size: 10px;
				letter-spacing: 4px;
				text-transform: uppercase;
				color: #444;
				display: block;
				margin-top: 52px;
				margin-bottom: 20px;
				padding-bottom: 16px;
				border-bottom: 1px solid #1a1a1a;
			}

			.favorites-grid {
				display: grid;
				grid-template-columns: repeat(4, minmax(0, 1fr));
				gap: 22px 18px;
			}

			.favorite-link {
				color: inherit;
				text-decoration: none;
				display: block;
			}

			.mobile-favorites-grid {
				display: none;
			}

			.favorite-link:hover .rec-cover,
			.favorite-link:focus-visible .rec-cover {
				border-color: #3a3a3a;
				transform: translateY(-2px);
			}

			.rec-cover {
				width: 100%;
				aspect-ratio: 2 / 3;
				border-radius: 4px;
				object-fit: cover;
				background: #151515;
				border: 1px solid #1e1e1e;
				display: block;
				transition: border-color 0.15s, transform 0.15s;
			}

			.rec-body {
				margin-top: 10px;
			}

			.rec-title {
				font-size: 14px;
				font-weight: 600;
				color: #e2dfd8;
				line-height: 1.25;
				margin-bottom: 4px;
			}

			.rec-subtitle {
				font-size: 11px;
				color: #555;
				line-height: 1.35;
			}

			/* === RESPONSIVE === */
			@media (max-width: 768px) {
				.wrap { padding: 36px 24px 60px; }
				.page-title { font-size: 36px; }
				.favorites-grid {
					grid-template-columns: repeat(3, minmax(0, 1fr));
					justify-content: center;
					gap: 26px 20px;
				}

				.desktop-favorites-grid {
					display: none;
				}

				.mobile-favorites-grid {
					display: grid;
				}
			}
		</style>
	</head>
	<body>
		<main class="wrap">
			<div>
				<a href="/" class="back-link">&larr; Back to Noah Eisen</a>
				<h1 class="page-title">Favorites</h1>
				<p class="page-desc">Some of my favorite movies and books, in no particular order.</p>
			</div>

			<span class="section-label">Movies</span>

			<div class="favorites-grid desktop-favorites-grid">
				{desktopFilms.map((film) => (
					<a class="favorite-link" href={film.url} target="_blank" rel="noopener noreferrer">
						<article>
							<img class="rec-cover" src={film.cover} alt={`${film.title} poster`} />
							<div class="rec-body">
								<div class="rec-title">{film.title}</div>
								<div class="rec-subtitle">{film.subtitle}</div>
							</div>
						</article>
					</a>
				))}
			</div>

			<div class="favorites-grid mobile-favorites-grid">
				{mobileFilms.map((film) => (
					<a class="favorite-link" href={film.url} target="_blank" rel="noopener noreferrer">
						<article>
							<img class="rec-cover" src={film.cover} alt={`${film.title} poster`} />
							<div class="rec-body">
								<div class="rec-title">{film.title}</div>
								<div class="rec-subtitle">{film.subtitle}</div>
							</div>
						</article>
					</a>
				))}
			</div>

			<span class="section-label">Books</span>

			<div class="favorites-grid desktop-favorites-grid">
				{desktopBooks.map((book) => (
					<a class="favorite-link" href={book.url} target="_blank" rel="noopener noreferrer">
						<article>
							<img class="rec-cover" src={book.cover} alt={`${book.title} cover`} />
							<div class="rec-body">
								<div class="rec-title">{book.title}</div>
								<div class="rec-subtitle">{book.subtitle}</div>
							</div>
						</article>
					</a>
				))}
			</div>

			<div class="favorites-grid mobile-favorites-grid">
				{mobileBooks.map((book) => (
					<a class="favorite-link" href={book.url} target="_blank" rel="noopener noreferrer">
						<article>
							<img class="rec-cover" src={book.cover} alt={`${book.title} cover`} />
							<div class="rec-body">
								<div class="rec-title">{book.title}</div>
								<div class="rec-subtitle">{book.subtitle}</div>
							</div>
						</article>
					</a>
				))}
			</div>
		</main>
	</body>
</html>
