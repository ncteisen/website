		<script>
			// Decode Google encoded polyline
			const decodePolyline = (encoded: string): [number, number][] => {
				const points: [number, number][] = [];
				let index = 0;
				let lat = 0;
				let lng = 0;

				while (index < encoded.length) {
					let shift = 0;
					let result = 0;
					let byte: number;

					do {
						byte = encoded.charCodeAt(index++) - 63;
						result |= (byte & 0x1f) << shift;
						shift += 5;
					} while (byte >= 0x20);
					lat += (result & 1) ? ~(result >> 1) : (result >> 1);

					shift = 0;
					result = 0;
					do {
						byte = encoded.charCodeAt(index++) - 63;
						result |= (byte & 0x1f) << shift;
						shift += 5;
					} while (byte >= 0x20);
					lng += (result & 1) ? ~(result >> 1) : (result >> 1);

					points.push([lat / 1e5, lng / 1e5]);
				}

				return points;
			};

			const initLatestActivityMaps = () => {
				document.querySelectorAll('.latest-activity-map').forEach(el => {
					const container = el as HTMLElement;
					const polyline = container.dataset.polyline;
					if (!polyline) return;

					const points = decodePolyline(polyline);
					if (points.length === 0) return;

					const map = (window as any).L.map(container.id, {
						zoomControl: false,
						attributionControl: false,
						dragging: false,
						scrollWheelZoom: false,
						doubleClickZoom: false,
						touchZoom: false,
						boxZoom: false,
						keyboard: false,
					});

					(window as any).L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
						maxZoom: 19,
					}).addTo(map);

					const line = (window as any).L.polyline(points, {
						color: '#5b8ef0',
						weight: 3,
						opacity: 0.9,
					}).addTo(map);

					map.fitBounds(line.getBounds(), { padding: [15, 15] });
				});
			};

			document.addEventListener('DOMContentLoaded', () => {
				// Initialize latest activity maps
				initLatestActivityMaps();

				// Review card click-to-open (can't use <a> wrapper because reviews contain links)
				document.querySelectorAll('.review-card[data-href]').forEach(card => {
					card.addEventListener('click', (e) => {
						if ((e.target as HTMLElement).closest('a')) return;
						window.open((card as HTMLElement).dataset.href!, '_blank');
					});
				});

				// Career item expansion
				document.querySelectorAll('[data-career]').forEach(item => {
					item.addEventListener('click', () => {
						item.classList.toggle('expanded');
					});
				});

				// Period toggle (This Year / Lifetime)
				const statsData = (window as any).__STATS_DATA__;
				const periodBtns = document.querySelectorAll('.period-btn');
				let currentPeriod = 'year';

				const updateStats = (period: string) => {
					currentPeriod = period;
					const data = statsData[period];
					const keys = ['films', 'books', 'runMiles', 'rideMiles'] as const;
					const labelKeys = ['filmsLabel', 'booksLabel', 'runLabel', 'rideLabel'] as const;

					keys.forEach((key, i) => {
						const valEl = document.querySelector(`[data-stat="${key}"]`);
						const lblEl = document.querySelector(`[data-stat-label="${key}"]`);
						if (valEl) valEl.textContent = Number(data[key]).toLocaleString();
						if (lblEl) lblEl.textContent = data[labelKeys[i]];
					});

					periodBtns.forEach(btn => {
						btn.classList.toggle('active', (btn as HTMLElement).dataset.period === period);
					});
				};

				periodBtns.forEach(btn => {
					btn.addEventListener('click', () => {
						updateStats((btn as HTMLElement).dataset.period || 'year');
					});
				});

				// Track social link clicks
				document.querySelectorAll('.hero-links a').forEach(link => {
					link.addEventListener('click', function(this: HTMLElement) {
						const href = this.getAttribute('href');
						let label = 'unknown';
						if (href?.includes('github.com')) label = 'github';
						else if (href?.includes('linkedin.com')) label = 'linkedin';
						else if (href?.includes('resume.pdf')) label = 'resume';
						else if (href?.includes('mailto:')) label = 'email';
						(window as any).gtag('event', 'click', {
							'event_category': 'social',
							'event_label': label
						});
					});
				});
			});
		</script>
	</body>
