			}

			.career-desc {
				font-size: 14px;
				color: #888;
				line-height: 1.75;
				margin: 0 0 16px;
			}

			.career-bullets {
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.career-bullets li {
