				flex-shrink: 0;
				filter: saturate(0.9);
			}

			/* === CAREER === */
			.career { margin-bottom: 56px; }

			.career-item {
				display: flex;
				gap: 28px;
				cursor: pointer;
				border-top: 1px solid #181818;
				padding: 22px 0;
			}

			.career-bar {
