const socialDataModules = await import.meta.glob('../data/social_data.json');
const socialData = (await socialDataModules['../data/social_data.json']()) as {
	letterboxd: {
		recent_reviews: MovieReview[],
		stats?: {
			total_films: number,
			films_this_year: number
		}
	},
	goodreads: {
		recent_reviews: BookReview[],
		stats?: {
			total_ratings: number,
			average_rating: number,
			total_reviews: number,
			books_this_year?: number
		}
	},
	strava: {
		recent_runs: StravaActivity[],
		recent_bikes: StravaActivity[],
		recent_hikes: StravaActivity[],
		stats?: {
			running: {
				ytd: ActivityTotals,
				all_time: ActivityTotals,
				recent: ActivityTotals
			},
			biking: {
				ytd: ActivityTotals,
				all_time: ActivityTotals,
				recent: ActivityTotals
			},
			swimming: {
				ytd: ActivityTotals,
				all_time: ActivityTotals,
				recent: ActivityTotals
			},
			biggest_ride_distance: number,
			biggest_climb_elevation_gain: number
		}
	}
};
const letterboxdData = socialData.letterboxd;
const goodreadsData = socialData.goodreads;
const stravaData = socialData.strava;

const resumeDataModules = await import.meta.glob('../../resume/resume_data.json');
const resumeData = (await resumeDataModules['../../resume/resume_data.json']()) as { experiences: WorkExperience[] };
const experiences = resumeData.experiences.filter((e) => !e.skip_web);

interface WorkItem {
	text: string;
	skip_pdf?: boolean;
	web_text?: string;
}

interface WorkExperience {
	company: string;
	title: string;
	location: string;
	start_date: string;
	end_date: string;
	skip_pdf?: boolean;
	skip_web?: boolean;
	icon: string;
	icon_prefix: string;
	description: string;
	web_description?: string;
	items: WorkItem[];
}

interface MovieReview {
	title: string;
	year: number;
	rating: number;
	watched_date: string;
	is_rewatch: boolean;
	review: string;
	image_url: string;
	link: string;
}

interface BookReview {
	title: string;
	author: string;
	rating: number;
	read_at: string;
	review: string;
	image_url: string;
	link: string;
}

interface StravaActivity {
	id: number;
	name: string;
	type: string;
	distance: number;
	moving_time: number;
	elapsed_time: number;
	elevation_gain: number;
	average_pace: number;
	average_heartrate: number | null;
	max_heartrate: number | null;
	average_cadence: number | null;
	average_watts: number | null;
	start_date: string;
	description: string | null;
	commute: boolean;
	map: {
		id: string;
		summary_polyline: string;
		resource_state: number;
	};
}

interface ActivityTotals {
	count: number;
	distance: number;
	moving_time: number;
	elapsed_time: number;
	elevation_gain: number;
}

const getStarRating = (rating: number): string => {
	const fullStars = Math.floor(rating);
	const hasHalfStar = rating % 1 >= 0.5;
	return '★'.repeat(fullStars) + (hasHalfStar ? '½' : '');
};

const getEmptyStars = (rating: number): string => {
	const fullStars = Math.floor(rating);
	const hasHalfStar = rating % 1 >= 0.5;
	const empty = 5 - fullStars - (hasHalfStar ? 1 : 0);
	return '★'.repeat(empty);
};

// Stats data for the period toggle (serialized to JSON for client-side use)
const statsData = {
	year: {
		films: letterboxdData.stats?.films_this_year || 0,
		filmsLabel: 'films watched this year',
		books: goodreadsData.stats?.books_this_year || 0,
		booksLabel: 'books read this year',
		runMiles: Math.round(stravaData.stats?.running.ytd.distance || 0),
		runLabel: 'miles run this year',
		rideMiles: Math.round(stravaData.stats?.biking.ytd.distance || 0),
		rideLabel: 'miles cycled this year',
	},
	lifetime: {
		films: letterboxdData.stats?.total_films || 0,
		filmsLabel: 'films logged, lifetime',
		books: goodreadsData.stats?.total_ratings || 0,
		booksLabel: 'books rated, lifetime',
		runMiles: Math.round(stravaData.stats?.running.all_time.distance || 0),
		runLabel: 'miles run, all time',
		rideMiles: Math.round(stravaData.stats?.biking.all_time.distance || 0),
		rideLabel: 'miles cycled, all time',
	}
};

// Featured reviews for pull quote
const featuredFilm = letterboxdData.recent_reviews[0];
const featuredBook = goodreadsData.recent_reviews[0];

const totalMovies = letterboxdData.recent_reviews.length;
const totalBooks = goodreadsData.recent_reviews.length;

const formatDate = (dateStr: string): string => {
	const d = new Date(dateStr);
	return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
};

const formatTime = (seconds: number): string => {
	const h = Math.floor(seconds / 3600);
	const m = Math.floor((seconds % 3600) / 60);
	const s = seconds % 60;
	if (h > 0) return `${h}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
	return `${m}:${String(s).padStart(2, '0')}`;
};

const latestRun = stravaData.recent_runs?.[0];
const latestBike = stravaData.recent_bikes?.[0];
