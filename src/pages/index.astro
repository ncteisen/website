---
const socialDataModules = await import.meta.glob('../data/social_data.json');
const socialData = (await socialDataModules['../data/social_data.json']()) as {
	letterboxd: {
		recent_reviews: MovieReview[],
		stats?: {
			total_films: number,
			films_this_year: number,
			total_lists: number,
			following_count: number,
			followers_count: number
		}
	},
	goodreads: {
		recent_reviews: BookReview[],
		stats?: {
			total_ratings: number,
			average_rating: number,
			total_reviews: number,
			books_this_year?: number,
			pages_this_year?: number
		}
	},
	strava: {
		recent_runs: StravaActivity[],
		recent_bikes: StravaActivity[],
		recent_hikes: StravaActivity[],
		stats?: {
			running: {
				ytd: ActivityTotals,
				all_time: ActivityTotals,
				recent: ActivityTotals
			},
			biking: {
				ytd: ActivityTotals,
				all_time: ActivityTotals,
				recent: ActivityTotals
			},
			swimming: {
				ytd: ActivityTotals,
				all_time: ActivityTotals,
				recent: ActivityTotals
			},
			biggest_ride_distance: number,
			biggest_climb_elevation_gain: number
		}
	}
};
const letterboxdData = socialData.letterboxd;
const goodreadsData = socialData.goodreads;
const stravaData = socialData.strava;

const resumeDataModules = await import.meta.glob('../../resume/resume_data.json');
const resumeData = (await resumeDataModules['../../resume/resume_data.json']()) as { experiences: WorkExperience[] };
const experiences = resumeData.experiences;

interface WorkItem {
	text: string;
	skip_pdf?: boolean;
	web_text?: string;
}

interface WorkExperience {
	company: string;
	title: string;
	location: string;
	start_date: string;
	end_date: string;
	skip_pdf?: boolean;
	icon: string;
	icon_prefix: string;
	description: string;
	web_description?: string;
	items: WorkItem[];
}

interface MovieReview {
	title: string;
	year: number;
	rating: number;
	watched_date: string;
	is_rewatch: boolean;
	review: string;
	image_url: string;
	link: string;
}

interface BookReview {
	title: string;
	author: string;
	rating: number;
	read_at: string;
	review: string;
	image_url: string;
	link: string;
}

interface StravaActivity {
	id: number;
	name: string;
	type: string;
	distance: number;
	moving_time: number;
	elapsed_time: number;
	elevation_gain: number;
	average_pace: number;
	average_heartrate: number | null;
	max_heartrate: number | null;
	average_cadence: number | null;
	average_watts: number | null;
	start_date: string;
	description: string | null;
	commute: boolean;
	map: {
		id: string;
		summary_polyline: string;
		resource_state: number;
	};
}

interface ActivityTotals {
	count: number;
	distance: number;
	moving_time: number;
	elapsed_time: number;
	elevation_gain: number;
}

const getStarRating = (rating: number): string => {
	const fullStars = Math.floor(rating);
	const hasHalfStar = rating % 1 >= 0.5;
	return '★'.repeat(fullStars) + (hasHalfStar ? '½' : '');
};

const getEmptyStars = (rating: number): string => {
	const fullStars = Math.floor(rating);
	const hasHalfStar = rating % 1 >= 0.5;
	const empty = 5 - fullStars - (hasHalfStar ? 1 : 0);
	return '★'.repeat(empty);
};

// Stats data for the period toggle (serialized to JSON for client-side use)
const statsData = {
	year: {
		films: letterboxdData.stats?.films_this_year || 0,
		filmsLabel: 'films watched this year',
		books: goodreadsData.stats?.books_this_year || 0,
		booksLabel: 'books read this year',
		runMiles: stravaData.stats?.running.ytd.distance || 0,
		runLabel: 'miles run this year',
		rideMiles: stravaData.stats?.biking.ytd.distance || 0,
		rideLabel: 'miles cycled this year',
	},
	lifetime: {
		films: letterboxdData.stats?.total_films || 0,
		filmsLabel: 'films logged, lifetime',
		books: goodreadsData.stats?.total_ratings || 0,
		booksLabel: 'books rated, lifetime',
		runMiles: stravaData.stats?.running.all_time.distance || 0,
		runLabel: 'miles run, all time',
		rideMiles: stravaData.stats?.biking.all_time.distance || 0,
		rideLabel: 'miles cycled, all time',
	}
};

// Featured reviews for pull quote
const featuredFilm = letterboxdData.recent_reviews[0];
const featuredBook = goodreadsData.recent_reviews[0];

const totalMovies = letterboxdData.recent_reviews.length;
const totalBooks = goodreadsData.recent_reviews.length;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Noah Eisen</title>
		<meta name="description" content="Engineer based in San Francisco with a decade of experience leading teams at Google, Waymo, Faire, and Roblox." />
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300;1,9..40,400&display=swap" rel="stylesheet" />
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-DW532NM54T"></script>
		<script>
			interface Window {
				dataLayer: any[];
				gtag: (...args: any[]) => void;
			}
			window.dataLayer = window.dataLayer || [];
			window.gtag = function() { window.dataLayer.push(arguments); };
			window.gtag('js', new Date());
			window.gtag('config', 'G-DW532NM54T');
		</script>
		<script define:vars={{ statsData }}>
			window.__STATS_DATA__ = statsData;
		</script>
		<style>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			html, body { height: 100%; }
			body {
				background: #0a0a0a;
				font-family: 'DM Sans', sans-serif;
				color: #e2dfd8;
				-webkit-font-smoothing: antialiased;
			}

			.wrap {
				max-width: 860px;
				margin: 0 auto;
				padding: 72px 44px 80px;
			}

			.rule {
				border: none;
				border-top: 1px solid #1e1e1e;
				margin: 56px 0;
			}

			.section-label {
				font-size: 10px;
				letter-spacing: 4px;
				text-transform: uppercase;
				color: #444;
				margin-bottom: 28px;
				display: block;
			}

			/* === HERO === */
			.hero {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				gap: 40px;
			}

			.hero h1 {
				font-size: 76px;
				font-weight: 700;
				letter-spacing: -3px;
				line-height: 0.92;
				margin: 0 0 20px;
				color: #eae7e0;
			}

			.hero-subtitle {
				font-size: 13px;
				color: #555;
				margin: 0 0 18px;
				letter-spacing: 2px;
				text-transform: uppercase;
			}

			.hero-bio {
				font-size: 15px;
				color: #999;
				margin: 0 0 24px;
				max-width: 460px;
				line-height: 1.75;
			}

			.hero-links {
				display: flex;
				gap: 28px;
			}

			.hero-links a {
				color: #5b8ef0;
				text-decoration: none;
				font-size: 13px;
				font-weight: 500;
				letter-spacing: 0.3px;
				transition: opacity 0.15s;
			}

			.hero-links a:hover { opacity: 0.8; }

			.profile-photo {
				width: 172px;
				height: 172px;
				border-radius: 50%;
				object-fit: cover;
				object-position: center 25%;
				border: 1px solid #2a2a2a;
				flex-shrink: 0;
				filter: saturate(0.9);
			}

			/* === CAREER === */
			.career { margin-bottom: 56px; }

			.career-item {
				display: flex;
				gap: 28px;
				cursor: pointer;
				border-top: 1px solid #181818;
				padding: 22px 0;
			}

			.career-bar {
				width: 2px;
				background: #232323;
				flex-shrink: 0;
				border-radius: 2px;
				transition: background 0.2s;
			}

			.career-item.expanded .career-bar {
				background: #5b8ef0;
			}

			.career-body { flex: 1; }

			.career-head {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 3px;
			}

			.career-company {
				font-size: 18px;
				font-weight: 600;
				color: #ccc;
				transition: color 0.2s;
			}

			.career-item.expanded .career-company { color: #e2dfd8; }

			.career-period {
				font-size: 11px;
				color: #444;
				letter-spacing: 1px;
				display: flex;
				align-items: center;
				gap: 10px;
				white-space: nowrap;
			}

			.career-arrow {
				color: #333;
				font-size: 14px;
				transition: transform 0.2s, color 0.2s;
				display: inline-block;
			}

			.career-item.expanded .career-arrow {
				transform: rotate(90deg);
				color: #5b8ef0;
			}

			.career-role {
				font-size: 13px;
				color: #666;
			}

			.career-details {
				max-height: 0;
				overflow: hidden;
				transition: max-height 0.3s ease;
			}

			.career-item.expanded .career-details {
				max-height: 2000px;
			}

			.career-details-inner {
				padding-top: 24px;
			}

			.career-desc {
				font-size: 14px;
				color: #888;
				line-height: 1.75;
				margin: 0 0 16px;
			}

			.career-bullets {
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.career-bullets li {
				font-size: 13px;
				color: #999;
				line-height: 1.7;
				padding-left: 18px;
				position: relative;
				margin-bottom: 10px;
			}

			.career-bullets li::before {
				content: '—';
				position: absolute;
				left: 0;
				top: 0;
				color: #5b8ef0;
			}

			.career-end { border-top: 1px solid #181818; }

			/* === PROJECTS === */
			.projects { margin-bottom: 56px; }

			.projects-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 14px;
			}

			.project-card {
				text-decoration: none;
				padding: 18px 20px;
				background: #111;
				border: 1px solid #1c1c1c;
				border-radius: 6px;
				display: block;
				transition: background 0.15s, border-color 0.15s;
			}

			.project-card:hover {
				background: #151515;
				border-color: #2a2a2a;
			}

			.project-card-title {
				font-size: 14px;
				font-weight: 600;
				color: #d4d0c8;
				margin-bottom: 6px;
			}

			.project-card-desc {
				font-size: 12px;
				color: #555;
				line-height: 1.6;
			}

			/* === STATS === */
			.stats-section { margin-bottom: 72px; }

			.stats-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-bottom: 28px;
			}

			.period-toggle {
				display: inline-flex;
				align-items: center;
				gap: 14px;
			}

			.period-btn {
				background: none;
				border: none;
				padding: 0;
				cursor: pointer;
				font-family: inherit;
				font-size: 10px;
				letter-spacing: 2px;
				text-transform: uppercase;
				font-weight: 500;
				color: #2e2e2e;
				border-bottom: 1px solid transparent;
				padding-bottom: 2px;
				transition: color 0.15s, border-color 0.15s;
			}

			.period-btn.active {
				color: #6a6a6a;
				border-bottom-color: #6a6a6a;
			}

			.period-sep {
				color: #1f1f1f;
				font-size: 10px;
			}

			.stats-row {
				display: flex;
				gap: 44px;
				border-top: 1px solid #1e1e1e;
				border-bottom: 1px solid #1e1e1e;
				padding: 28px 0;
			}

			.stat-cell { flex: 1; min-width: 0; }

			.stat-value {
				font-size: 34px;
				font-weight: 700;
				color: #eae7e0;
				line-height: 1;
				letter-spacing: -1px;
				margin-bottom: 6px;
			}

			.stat-label {
				font-size: 11px;
				color: #555;
				letter-spacing: 0.3px;
			}

			.stat-divider {
				width: 1px;
				background: #1a1a1a;
			}

			/* === FEATURED REVIEW === */
			.review-section { margin-bottom: 72px; }

			.review-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-bottom: 24px;
				gap: 16px;
			}

			.kind-tabs {
				display: inline-flex;
				align-items: center;
				gap: 18px;
			}

			.kind-tab {
				background: none;
				border: none;
				padding: 4px 0;
				cursor: pointer;
				font-family: inherit;
				font-size: 11px;
				letter-spacing: 2px;
				text-transform: uppercase;
				font-weight: 500;
				color: #4a4a4a;
				border-bottom: 1px solid transparent;
				transition: color 0.15s, border-color 0.15s;
			}

			.kind-tab.active {
				color: #5b8ef0;
				border-bottom-color: #5b8ef0;
			}

			.review-grid {
				display: grid;
				grid-template-columns: 140px 1fr;
				gap: 32px;
				align-items: start;
			}

			.review-cover {
				width: 140px;
				height: 210px;
				border-radius: 4px;
				object-fit: cover;
				background: #151515;
				border: 1px solid #1e1e1e;
			}

			.review-cover-placeholder {
				width: 140px;
				height: 210px;
				border-radius: 4px;
				background: linear-gradient(145deg, #1a2236, #0f1420);
				border: 1px solid #1e1e1e;
				display: flex;
				align-items: center;
				justify-content: center;
				color: #5b8ef0;
				font-size: 49px;
				font-weight: 700;
				letter-spacing: 2px;
			}

			.review-date {
				font-size: 10px;
				color: #3a3a3a;
				letter-spacing: 1.5px;
				margin-bottom: 8px;
			}

			.review-title {
				font-size: 34px;
				font-weight: 700;
				color: #eae7e0;
				line-height: 1.05;
				letter-spacing: -0.8px;
				margin-bottom: 8px;
			}

			.review-subtitle {
				font-size: 13px;
				color: #666;
				margin-bottom: 14px;
			}

			.review-stars {
				margin-bottom: 20px;
			}

			.stars {
				letter-spacing: 1.5px;
				display: inline-flex;
				gap: 1px;
			}

			.stars-filled { color: #d4a84b; }
			.stars-dim { color: #2a2a2a; }

			.review-quote {
				margin: 0;
				padding: 4px 0 4px 18px;
				border-left: 2px solid #5b8ef0;
				position: relative;
			}

			.review-quote-mark {
				position: absolute;
				left: -2px;
				top: -14px;
				font-size: 40px;
				color: #5b8ef0;
				font-family: Georgia, serif;
				line-height: 1;
				opacity: 0.5;
			}

			.review-quote p {
				font-size: 17px;
				color: #c8c5be;
				line-height: 1.65;
				margin: 0;
				font-style: italic;
				font-weight: 300;
			}

			.review-quote footer {
				font-size: 11px;
				color: #444;
				letter-spacing: 1.5px;
				text-transform: uppercase;
				margin-top: 14px;
			}

			/* === JOURNAL LINK === */
			.journal-link {
				display: block;
				text-decoration: none;
				background: #101010;
				border: 1px solid #1c1c1c;
				border-radius: 8px;
				padding: 28px 32px;
				transition: background 0.15s, border-color 0.15s;
			}

			.journal-link:hover {
				background: #131313;
				border-color: #2a2a2a;
			}

			.journal-link-inner {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 24px;
			}

			.journal-link-label {
				font-size: 10px;
				letter-spacing: 3px;
				text-transform: uppercase;
				color: #5b8ef0;
				margin-bottom: 8px;
			}

			.journal-link-title {
				font-size: 20px;
				font-weight: 600;
				color: #e2dfd8;
				margin-bottom: 4px;
			}

			.journal-link-meta {
				font-size: 13px;
				color: #666;
			}

			.journal-link-arrow {
				font-size: 28px;
				color: #5b8ef0;
				font-weight: 300;
			}

			/* === FOOTER === */
			.site-footer {
				font-size: 12px;
				color: #333;
				text-align: center;
			}

			/* === HIDDEN UTILITY === */
			.hidden { display: none !important; }

			/* === RESPONSIVE === */
			@media (max-width: 768px) {
				.wrap { padding: 48px 24px 60px; }

				.hero {
					flex-direction: column-reverse;
					align-items: center;
					text-align: center;
					gap: 24px;
				}

				.hero h1 { font-size: 48px; letter-spacing: -2px; }
				.hero-bio { max-width: 100%; }
				.hero-links { justify-content: center; gap: 20px; flex-wrap: wrap; }
				.profile-photo { width: 120px; height: 120px; }

				.projects-grid { grid-template-columns: 1fr; }

				.stats-row {
					flex-direction: column;
					gap: 24px;
				}

				.stat-divider {
					width: 100%;
					height: 1px;
				}

				.review-grid {
					grid-template-columns: 100px 1fr;
					gap: 20px;
				}

				.review-cover, .review-cover-placeholder {
					width: 100px;
					height: 150px;
				}

				.review-title { font-size: 24px; }

				.review-quote p { font-size: 15px; }
			}

			@media (max-width: 480px) {
				.hero h1 { font-size: 40px; }
				.stats-header { flex-direction: column; align-items: flex-start; gap: 12px; }
				.review-header { flex-direction: column; align-items: flex-start; gap: 12px; }
			}
		</style>
	</head>
	<body>
		<main class="wrap">

			<!-- HERO -->
			<header class="hero">
				<div>
					<h1>NOAH<br />EISEN</h1>
					<p class="hero-subtitle">
						Principal Software Engineer &nbsp;·&nbsp; Roblox &nbsp;·&nbsp; San Francisco, CA
					</p>
					<p class="hero-bio">
						I build systems that scale and teams that ship. Previously Google, Waymo, Faire, 
						Roblox. Unreasonably opinionated about software architecture, film, and whatever 
						I'm currently reading. Probably also training for something.
					</p>
					<div class="hero-links">
						<a href="https://github.com/ncteisen" target="_blank" rel="noopener noreferrer">GitHub</a>
						<a href="https://linkedin.com/in/ncteisen" target="_blank" rel="noopener noreferrer">LinkedIn</a>
						<a href="mailto:ncteisen@gmail.com">Email</a>
						<a href="/resume.pdf" target="_blank" rel="noopener noreferrer">Resume</a>
					</div>
				</div>
				<img
					src="/images/profile-placeholder.jpg"
					alt="Noah Eisen"
					class="profile-photo"
				/>
			</header>

			<hr class="rule" />

			<!-- CAREER -->
			<section class="career">
				<span class="section-label">Career</span>
				{experiences.map((exp) => (
					<div class="career-item" data-career>
						<div class="career-bar"></div>
						<div class="career-body">
							<div class="career-head">
								<span class="career-company">{exp.company}</span>
								<span class="career-period">
									{exp.start_date} – {exp.end_date}
									<span class="career-arrow">›</span>
								</span>
							</div>
							<div class="career-role">{exp.title}</div>
							<div class="career-details">
								<div class="career-details-inner">
									<p class="career-desc">{exp.web_description ?? exp.description}</p>
									<ul class="career-bullets">
										{exp.items.map((item) => (
											<li set:html={item.web_text ?? item.text}></li>
										))}
									</ul>
								</div>
							</div>
						</div>
					</div>
				))}
				<div class="career-end"></div>
			</section>

			<!-- PROJECTS -->
			<section class="projects">
				<span class="section-label">Projects</span>
				<div class="projects-grid">
					<a href="/projects/sarah-jumps" class="project-card">
						<div class="project-card-title">Sarah Jumps</div>
						<div class="project-card-desc">Doodle Jump–inspired game built to explore vibe coding.</div>
					</a>
					<a href="https://www.hypertextlibrary.com/" class="project-card" target="_blank" rel="noopener noreferrer">
						<div class="project-card-title">Hypertext Library</div>
						<div class="project-card-desc">Literature-based web project built after a class on Ulysses.</div>
					</a>
					<a href="/old/projects/p1/" class="project-card">
						<div class="project-card-title">Room Game</div>
						<div class="project-card-desc">Text-based adventure game built in college to teach myself JavaScript.</div>
					</a>
				</div>
			</section>

			<!-- BY THE NUMBERS -->
			<section class="stats-section">
				<div class="stats-header">
					<span class="section-label" style="margin-bottom:0">By the Numbers</span>
					<div class="period-toggle">
						<button class="period-btn active" data-period="year">This Year</button>
						<span class="period-sep">/</span>
						<button class="period-btn" data-period="lifetime">Lifetime</button>
					</div>
				</div>
				<div class="stats-row">
					<div class="stat-cell">
						<div class="stat-value" data-stat="films">{statsData.year.films}</div>
						<div class="stat-label" data-stat-label="films">{statsData.year.filmsLabel}</div>
					</div>
					<div class="stat-divider"></div>
					<div class="stat-cell">
						<div class="stat-value" data-stat="books">{statsData.year.books}</div>
						<div class="stat-label" data-stat-label="books">{statsData.year.booksLabel}</div>
					</div>
					<div class="stat-divider"></div>
					<div class="stat-cell">
						<div class="stat-value" data-stat="runMiles">{statsData.year.runMiles}</div>
						<div class="stat-label" data-stat-label="runMiles">{statsData.year.runLabel}</div>
					</div>
					<div class="stat-divider"></div>
					<div class="stat-cell">
						<div class="stat-value" data-stat="rideMiles">{statsData.year.rideMiles}</div>
						<div class="stat-label" data-stat-label="rideMiles">{statsData.year.rideLabel}</div>
					</div>
				</div>
			</section>

			<!-- LATEST REVIEW -->
			<section class="review-section">
				<div class="review-header">
					<span class="section-label" style="margin-bottom:0">Latest Review</span>
					<div class="kind-tabs">
						<button class="kind-tab active" data-kind="film">Film</button>
						<button class="kind-tab" data-kind="book">Book</button>
					</div>
				</div>

				<!-- Film review -->
				<div class="review-grid" data-review="film">
					{featuredFilm?.image_url ? (
						<img src={featuredFilm.image_url} alt={featuredFilm.title} class="review-cover" />
					) : (
						<div class="review-cover-placeholder">▸</div>
					)}
					<div>
						<div class="review-date">{featuredFilm?.watched_date}</div>
						<div class="review-title">{featuredFilm?.title}</div>
						<div class="review-subtitle">{featuredFilm?.year}</div>
						<div class="review-stars">
							<span class="stars">
								<span class="stars-filled">{getStarRating(featuredFilm?.rating || 0)}</span><span class="stars-dim">{getEmptyStars(featuredFilm?.rating || 0)}</span>
							</span>
						</div>
						<blockquote class="review-quote">
							<span class="review-quote-mark">"</span>
							<div set:html={featuredFilm?.review} />
							<footer>— Noah's review</footer>
						</blockquote>
					</div>
				</div>

				<!-- Book review -->
				<div class="review-grid hidden" data-review="book">
					{featuredBook?.image_url ? (
						<img src={featuredBook.image_url} alt={featuredBook.title} class="review-cover" />
					) : (
						<div class="review-cover-placeholder">📖</div>
					)}
					<div>
						<div class="review-date">{featuredBook?.read_at}</div>
						<div class="review-title">{featuredBook?.title}</div>
						<div class="review-subtitle">{featuredBook?.author}</div>
						<div class="review-stars">
							<span class="stars">
								<span class="stars-filled">{getStarRating(featuredBook?.rating || 0)}</span><span class="stars-dim">{getEmptyStars(featuredBook?.rating || 0)}</span>
							</span>
						</div>
						<blockquote class="review-quote">
							<span class="review-quote-mark">"</span>
							<div set:html={featuredBook?.review} />
							<footer>— Noah's review</footer>
						</blockquote>
					</div>
				</div>
			</section>

			<!-- JOURNAL LINK -->
			<section>
				<a href="/journal" class="journal-link">
					<div class="journal-link-inner">
						<div>
							<div class="journal-link-label">Full Journal</div>
							<div class="journal-link-title">Read every film & book review</div>
							<div class="journal-link-meta">{totalMovies} films · {totalBooks} books · sorted by date</div>
						</div>
						<div class="journal-link-arrow">→</div>
					</div>
				</a>
			</section>

			<hr class="rule" />
			<footer class="site-footer">© {new Date().getFullYear()} Noah Eisen</footer>
		</main>

		<script>
			document.addEventListener('DOMContentLoaded', () => {
				// Career item expansion
				document.querySelectorAll('[data-career]').forEach(item => {
					item.addEventListener('click', () => {
						item.classList.toggle('expanded');
					});
				});

				// Period toggle (This Year / Lifetime)
				const statsData = (window as any).__STATS_DATA__;
				const periodBtns = document.querySelectorAll('.period-btn');
				let currentPeriod = 'year';

				const updateStats = (period: string) => {
					currentPeriod = period;
					const data = statsData[period];
					const keys = ['films', 'books', 'runMiles', 'rideMiles'] as const;
					const labelKeys = ['filmsLabel', 'booksLabel', 'runLabel', 'rideLabel'] as const;

					keys.forEach((key, i) => {
						const valEl = document.querySelector(`[data-stat="${key}"]`);
						const lblEl = document.querySelector(`[data-stat-label="${key}"]`);
						if (valEl) valEl.textContent = String(data[key]);
						if (lblEl) lblEl.textContent = data[labelKeys[i]];
					});

					periodBtns.forEach(btn => {
						btn.classList.toggle('active', (btn as HTMLElement).dataset.period === period);
					});
				};

				periodBtns.forEach(btn => {
					btn.addEventListener('click', () => {
						updateStats((btn as HTMLElement).dataset.period || 'year');
					});
				});

				// Kind tabs (Film / Book)
				const kindTabs = document.querySelectorAll('.kind-tab');
				const filmReview = document.querySelector('[data-review="film"]');
				const bookReview = document.querySelector('[data-review="book"]');

				kindTabs.forEach(tab => {
					tab.addEventListener('click', () => {
						const kind = (tab as HTMLElement).dataset.kind;
						kindTabs.forEach(t => t.classList.toggle('active', t === tab));

						if (kind === 'film') {
							filmReview?.classList.remove('hidden');
							bookReview?.classList.add('hidden');
						} else {
							filmReview?.classList.add('hidden');
							bookReview?.classList.remove('hidden');
						}
					});
				});

				// Track social link clicks
				document.querySelectorAll('.hero-links a').forEach(link => {
					link.addEventListener('click', function(this: HTMLElement) {
						const href = this.getAttribute('href');
						let label = 'unknown';
						if (href?.includes('github.com')) label = 'github';
						else if (href?.includes('linkedin.com')) label = 'linkedin';
						else if (href?.includes('resume.pdf')) label = 'resume';
						else if (href?.includes('mailto:')) label = 'email';
						(window as any).gtag('event', 'click', {
							'event_category': 'social',
							'event_label': label
						});
					});
				});
			});
		</script>
	</body>
</html>
