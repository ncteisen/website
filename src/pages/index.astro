					grid-template-columns: 1fr;
					gap: 24px;
				}
			}

			@media (max-width: 480px) {
				.hero h1 { font-size: 40px; }
				.stats-header { flex-direction: column; align-items: flex-start; gap: 12px; }
			}
		</style>
	</head>
	<body>
		<main class="wrap">

			<!-- HERO -->
			<header class="hero">
				<div>
					<h1>NOAH<br />EISEN</h1>
