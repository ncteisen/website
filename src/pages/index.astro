			}

			.section-label {
				font-size: 10px;
				letter-spacing: 4px;
				text-transform: uppercase;
				color: #444;
				margin-bottom: 28px;
				display: block;
			}

			/* === HERO === */
			.hero {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				gap: 40px;
			}

			.hero h1 {
