		<style>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			html, body { height: 100%; }
			body {
				background: #0a0a0a;
				font-family: 'DM Sans', sans-serif;
				color: #e2dfd8;
				-webkit-font-smoothing: antialiased;
			}

			.wrap {
				max-width: 860px;
				margin: 0 auto;
				padding: 72px 44px 80px;
			}

			.rule {
				border: none;
				border-top: 1px solid #1e1e1e;
