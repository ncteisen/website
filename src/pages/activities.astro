---
const socialDataModules = await import.meta.glob('../data/social_data.json');
const socialData = (await socialDataModules['../data/social_data.json']()) as {
	strava: {
		all_activities: StravaActivity[],
	},
};

interface StravaActivity {
	id: number;
	name: string;
	type: string;
	distance: number;
	moving_time: number;
	elapsed_time: number;
	elevation_gain: number;
	average_pace: number;
	start_date: string;
	map: { id: string; summary_polyline: string; resource_state: number };
}

const allActivities = socialData.strava.all_activities || [];

const INITIAL_SHOW = 20;
const LOAD_MORE_COUNT = 20;
const runCount = allActivities.filter(a => a.type === 'Run').length;
const rideCount = allActivities.filter(a => a.type === 'Ride').length;
const hikeCount = allActivities.filter(a => a.type === 'Hike').length;

const formatDate = (dateStr: string): string => {
	const d = new Date(dateStr);
	return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
};

const formatTime = (seconds: number): string => {
	const h = Math.floor(seconds / 3600);
	const m = Math.floor((seconds % 3600) / 60);
	const s = seconds % 60;
	if (h > 0) return `${h}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
	return `${m}:${String(s).padStart(2, '0')}`;
};

const typeLabel = (type: string): string => {
	if (type === 'Ride') return 'RIDE';
	if (type === 'Hike') return 'HIKE';
	return 'RUN';
};

const typeClass = (type: string): string => {
	if (type === 'Ride') return 'ride';
	if (type === 'Hike') return 'hike';
	return 'run';
};

const filterKey = (type: string): string => {
	if (type === 'Ride') return 'ride';
	if (type === 'Hike') return 'hike';
	return 'run';
};
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Activity Log — Noah Eisen</title>
		<meta name="description" content="Noah Eisen's recent runs, rides, and hikes from Strava." />
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300;1,9..40,400&display=swap" rel="stylesheet" />
		<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
		<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-DW532NM54T"></script>
		<script>
			interface Window {
				dataLayer: any[];
				gtag: (...args: any[]) => void;
			}
			window.dataLayer = window.dataLayer || [];
			window.gtag = function() { window.dataLayer.push(arguments); };
			window.gtag('js', new Date());
			window.gtag('config', 'G-DW532NM54T');
		</script>
		<style>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			html, body { height: 100%; }
			body {
				background: #0a0a0a;
				font-family: 'DM Sans', sans-serif;
				color: #e2dfd8;
				-webkit-font-smoothing: antialiased;
			}

			.wrap {
				max-width: 920px;
				margin: 0 auto;
				padding: 52px 44px 80px;
			}

			/* === HEADER === */
			.back-link {
				font-size: 11px;
				color: #666;
				text-decoration: none;
				letter-spacing: 1px;
				text-transform: uppercase;
				display: inline-flex;
				align-items: center;
				gap: 8px;
				margin-bottom: 28px;
				transition: color 0.15s;
			}

			.back-link:hover { color: #999; }

			.page-title {
				font-size: 48px;
				font-weight: 700;
				letter-spacing: -1.5px;
				margin: 0 0 10px;
				color: #eae7e0;
				line-height: 1;
			}

			.page-desc {
				font-size: 14px;
				color: #777;
				margin: 0;
				line-height: 1.7;
				max-width: 520px;
			}

			.page-sources {
				font-size: 12px;
				color: #444;
				margin: 10px 0 0;
				letter-spacing: 0.3px;
			}

			.page-sources a {
				color: #5b8ef0;
				text-decoration: none;
				transition: opacity 0.15s;
			}

			.page-sources a:hover { opacity: 0.8; }

			/* === FILTERS === */
			.filters {
				display: flex;
				gap: 10px;
				margin: 44px 0 36px;
				border-bottom: 1px solid #1a1a1a;
				padding-bottom: 24px;
			}

			.filter-btn {
				background: transparent;
				border: 1px solid #1c1c1c;
				color: #666;
				padding: 8px 16px;
				border-radius: 6px;
				font-family: inherit;
				font-size: 12px;
				font-weight: 500;
				letter-spacing: 0.5px;
				cursor: pointer;
				display: inline-flex;
				align-items: center;
				gap: 8px;
				transition: all 0.15s;
			}

			.filter-btn.active {
				background: #101010;
				border-color: #2a2a2a;
				color: #e2dfd8;
			}

			.filter-btn .count {
				font-size: 10px;
				color: #444;
			}

			.filter-btn.active .count {
				color: #5b8ef0;
			}

			/* === ENTRIES === */
			.entry {
				display: grid;
				grid-template-columns: 180px 1fr;
				gap: 28px;
				padding: 28px 0;
				border-top: 1px solid #181818;
			}

			.entry-map {
				width: 180px;
				height: 140px;
				border-radius: 6px;
				background: #111;
				border: 1px solid #1e1e1e;
				overflow: hidden;
			}

			/* Hide Leaflet controls and attribution on thumbnails */
			.entry-map .leaflet-control-zoom,
			.entry-map .leaflet-control-attribution {
				display: none !important;
			}

			.entry-meta {
				display: flex;
				align-items: center;
				gap: 12px;
				margin-bottom: 10px;
				flex-wrap: wrap;
			}

			.entry-badge {
				font-size: 9px;
				letter-spacing: 2px;
				font-weight: 600;
				padding: 2px 7px;
				border-radius: 3px;
			}

			.entry-badge.run {
				color: #5b8ef0;
				border: 1px solid rgba(91, 142, 240, 0.25);
			}

			.entry-badge.ride {
				color: #d4a84b;
				border: 1px solid rgba(212, 168, 75, 0.25);
			}

			.entry-badge.hike {
				color: #6bc77a;
				border: 1px solid rgba(107, 199, 122, 0.25);
			}

			.entry-date {
				font-size: 11px;
				color: #444;
				letter-spacing: 1px;
			}

			.entry-title {
				font-size: 19px;
				font-weight: 600;
				color: #e2dfd8;
				line-height: 1.3;
				margin-bottom: 12px;
			}

			.entry-stats {
				display: flex;
				gap: 24px;
				flex-wrap: wrap;
			}

			.entry-stat {
				display: flex;
				flex-direction: column;
				gap: 2px;
			}

			.entry-stat-value {
				font-size: 15px;
				font-weight: 600;
				color: #e2dfd8;
			}

			.entry-stat-label {
				font-size: 10px;
				color: #555;
				letter-spacing: 1.5px;
				text-transform: uppercase;
			}

			.entry-link {
				display: inline-block;
				margin-top: 12px;
				font-size: 11px;
				color: #333;
				text-decoration: none;
				letter-spacing: 0.5px;
				transition: color 0.15s;
			}

			.entry-link:hover { color: #5b8ef0; }

			/* === END === */
			.page-end {
				border-top: 1px solid #181818;
				padding-top: 24px;
				font-size: 11px;
				color: #333;
				letter-spacing: 2px;
				text-transform: uppercase;
			}

			.page-end a {
				color: #555;
				text-decoration: none;
				transition: color 0.15s;
			}

			.page-end a:hover { color: #5b8ef0; }

			/* === LOAD MORE === */
			.load-more-btn {
				display: block;
				width: 100%;
				padding: 16px;
				margin: 8px 0;
				background: transparent;
				border: 1px solid #1c1c1c;
				color: #666;
				font-family: inherit;
				font-size: 12px;
				font-weight: 500;
				letter-spacing: 1px;
				text-transform: uppercase;
				cursor: pointer;
				border-radius: 6px;
				transition: all 0.15s;
			}

			.load-more-btn:hover {
				border-color: #2a2a2a;
				color: #e2dfd8;
			}

			.load-more-btn .count {
				color: #444;
				font-size: 10px;
			}

			/* === HIDDEN === */
			.hidden { display: none !important; }

			/* === RESPONSIVE === */
			@media (max-width: 768px) {
				.wrap { padding: 36px 24px 60px; }
				.page-title { font-size: 36px; }

				.entry {
					grid-template-columns: 140px 1fr;
					gap: 16px;
				}

				.entry-map {
					width: 140px;
					height: 110px;
				}

				.entry-title { font-size: 16px; }
				.entry-stats { gap: 16px; }
			}

			@media (max-width: 480px) {
				.entry {
					grid-template-columns: 1fr;
					gap: 12px;
				}

				.entry-map {
					width: 100%;
					height: 160px;
				}
			}
		</style>
	</head>
	<body>
		<main class="wrap">

			<!-- HEADER -->
			<div>
				<a href="/" class="back-link">← Back to Noah Eisen</a>
				<h1 class="page-title">Activity Log</h1>
				<p class="page-desc">My 100 most recent runs, rides, and hikes. Updated daily.</p>
				<p class="page-sources">Sourced from my <a href="https://www.strava.com/athletes/ncteisen" target="_blank" rel="noopener noreferrer">Strava</a>.</p>
			</div>

			<!-- FILTERS -->
			<div class="filters">
				<button class="filter-btn active" data-filter="all">
					All <span class="count">{allActivities.length}</span>
				</button>
				<button class="filter-btn" data-filter="run">
					Runs <span class="count">{runCount}</span>
				</button>
				<button class="filter-btn" data-filter="ride">
					Rides <span class="count">{rideCount}</span>
				</button>
				{hikeCount > 0 && (
					<button class="filter-btn" data-filter="hike">
						Hikes <span class="count">{hikeCount}</span>
					</button>
				)}
			</div>

			<!-- ENTRIES -->
			<div class="entries">
				{allActivities.map((activity, i) => (
					<article class={`entry ${i >= INITIAL_SHOW ? 'hidden' : ''}`} data-entry-kind={filterKey(activity.type)} data-index={i}>
						<div class="entry-map" id={`map-${activity.id}`} data-polyline={activity.map?.summary_polyline || ''}></div>
						<div>
							<div class="entry-meta">
								<span class={`entry-badge ${typeClass(activity.type)}`}>
									{typeLabel(activity.type)}
								</span>
								<span class="entry-date">{formatDate(activity.start_date)}</span>
							</div>
							<div class="entry-title">{activity.name}</div>
							<div class="entry-stats">
								<div class="entry-stat">
									<span class="entry-stat-value">{activity.distance.toFixed(1)} mi</span>
									<span class="entry-stat-label">Distance</span>
								</div>
								<div class="entry-stat">
									<span class="entry-stat-value">{activity.elevation_gain.toLocaleString()} ft</span>
									<span class="entry-stat-label">Elevation</span>
								</div>
								<div class="entry-stat">
									<span class="entry-stat-value">{formatTime(activity.moving_time)}</span>
									<span class="entry-stat-label">Time</span>
								</div>
							</div>
							<a href={`https://www.strava.com/activities/${activity.id}`} target="_blank" rel="noopener noreferrer" class="entry-link">
								Strava →
							</a>
						</div>
					</article>
				))}
				{allActivities.length > INITIAL_SHOW && (
					<button class="load-more-btn" id="load-more">
						Load More <span class="count">({allActivities.length - INITIAL_SHOW} remaining)</span>
					</button>
				)}
				<div class="page-end">
					<a href="https://www.strava.com/athletes/ncteisen" target="_blank" rel="noopener noreferrer">Strava</a>
				</div>
			</div>
		</main>

		<script>
			// Decode Google encoded polyline
			const decodePolyline = (encoded: string): [number, number][] => {
				const points: [number, number][] = [];
				let index = 0;
				let lat = 0;
				let lng = 0;

				while (index < encoded.length) {
					let shift = 0;
					let result = 0;
					let byte: number;

					do {
						byte = encoded.charCodeAt(index++) - 63;
						result |= (byte & 0x1f) << shift;
						shift += 5;
					} while (byte >= 0x20);
					lat += (result & 1) ? ~(result >> 1) : (result >> 1);

					shift = 0;
					result = 0;
					do {
						byte = encoded.charCodeAt(index++) - 63;
						result |= (byte & 0x1f) << shift;
						shift += 5;
					} while (byte >= 0x20);
					lng += (result & 1) ? ~(result >> 1) : (result >> 1);

					points.push([lat / 1e5, lng / 1e5]);
				}

				return points;
			};

			const initMaps = () => {
				const mapContainers = document.querySelectorAll('.entry-map');
				mapContainers.forEach(container => {
					const el = container as HTMLElement;
					// Skip if already initialized
					if (el.dataset.initialized === 'true') return;
					// Skip if hidden
					if (el.closest('.hidden')) return;

					const polyline = el.dataset.polyline;
					if (!polyline) return;

					const points = decodePolyline(polyline);
					if (points.length === 0) return;

					const map = (window as any).L.map(el.id, {
						zoomControl: false,
						attributionControl: false,
						dragging: false,
						scrollWheelZoom: false,
						doubleClickZoom: false,
						touchZoom: false,
						boxZoom: false,
						keyboard: false,
					});

					(window as any).L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
						maxZoom: 19,
					}).addTo(map);

					const line = (window as any).L.polyline(points, {
						color: '#5b8ef0',
						weight: 3,
						opacity: 0.9,
					}).addTo(map);

					map.fitBounds(line.getBounds(), { padding: [15, 15] });
					el.dataset.initialized = 'true';
				});
			};

			document.addEventListener('DOMContentLoaded', () => {
				const LOAD_MORE_COUNT = 20;
				const filterBtns = document.querySelectorAll('.filter-btn');
				const entries = document.querySelectorAll('.entry');
				const loadMoreBtn = document.getElementById('load-more') as HTMLButtonElement | null;

				let currentFilter = 'all';
				let visibleLimit = 20;

				const applyVisibility = () => {
					let matchCount = 0;
					let hiddenByLimit = 0;
					entries.forEach(entry => {
						const el = entry as HTMLElement;
						const kind = el.dataset.entryKind;
						const matchesFilter = currentFilter === 'all' || kind === currentFilter;
						if (matchesFilter) {
							matchCount++;
							if (matchCount <= visibleLimit) {
								el.classList.remove('hidden');
							} else {
								el.classList.add('hidden');
								hiddenByLimit++;
							}
						} else {
							el.classList.add('hidden');
						}
					});

					if (loadMoreBtn) {
						if (hiddenByLimit > 0) {
							loadMoreBtn.classList.remove('hidden');
							const countSpan = loadMoreBtn.querySelector('.count');
							if (countSpan) countSpan.textContent = `(${hiddenByLimit} remaining)`;
						} else {
							loadMoreBtn.classList.add('hidden');
						}
					}

					// Initialize maps for newly visible entries
					setTimeout(initMaps, 50);
				};

				filterBtns.forEach(btn => {
					btn.addEventListener('click', () => {
						currentFilter = (btn as HTMLElement).dataset.filter || 'all';
						filterBtns.forEach(b => b.classList.toggle('active', b === btn));
						visibleLimit = 20;
						applyVisibility();
					});
				});

				if (loadMoreBtn) {
					loadMoreBtn.addEventListener('click', () => {
						visibleLimit += LOAD_MORE_COUNT;
						applyVisibility();
					});
				}

				// Initialize maps for initially visible entries
				initMaps();
			});
		</script>
	</body>
</html>
