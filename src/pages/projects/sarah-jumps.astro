---
import UmamiAnalytics from '../../components/UmamiAnalytics.astro';
import SocialPreview from '../../components/SocialPreview.astro';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Sarah Jumps | Noah Eisen</title>
		<SocialPreview
			title="Noah Eisen - Sarah Jumps"
			description="A Doodle Jump clone game built with JavaScript"
			path="/projects/sarah-jumps/"
		/>
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300;1,9..40,400&display=swap" rel="stylesheet" />
		<UmamiAnalytics />
		<style>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			html, body { min-height: 100%; }

			body {
				background: #0a0a0a;
				font-family: 'DM Sans', sans-serif;
				color: #e2dfd8;
				-webkit-font-smoothing: antialiased;
			}

			.wrap {
				max-width: 860px;
				margin: 0 auto;
				padding: 72px 44px 80px;
			}

			.project-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				gap: 40px;
			}

			.project-title {
				font-size: 76px;
				font-weight: 700;
				letter-spacing: -3px;
				line-height: 0.92;
				margin: 0 0 20px;
				color: #eae7e0;
			}

			.project-subtitle {
				font-size: 13px;
				color: #555;
				margin: 0 0 18px;
				letter-spacing: 2px;
				text-transform: uppercase;
			}

			.project-description {
				font-size: 14px;
				color: #999;
				margin: 0;
				max-width: 500px;
				line-height: 1.75;
			}

			.rule {
				border: none;
				border-top: 1px solid #1e1e1e;
				margin: 56px 0;
			}

			.section-label {
				font-size: 10px;
				letter-spacing: 4px;
				text-transform: uppercase;
				color: #444;
				margin-bottom: 28px;
				display: block;
			}

			.back-link {
				display: inline-block;
				color: #5b8ef0;
				text-decoration: none;
				font-size: 13px;
				font-weight: 500;
				letter-spacing: 0.3px;
				white-space: nowrap;
				transition: opacity 0.15s;
			}

			.back-link:hover { opacity: 0.8; }

			.game-container {
				display: flex;
				justify-content: center;
				align-items: center;
			}

			.game-window {
				width: min(100%, 400px);
				aspect-ratio: 2 / 3;
				background: #111;
				border: 1px solid #1c1c1c;
				border-radius: 6px;
				overflow: hidden;
				position: relative;
				box-shadow: 0 24px 70px rgba(0, 0, 0, 0.35);
			}

			.game-canvas {
				width: 100%;
				height: 100%;
				background-color: #f0f0f0;
				display: block;
				touch-action: none;
				user-select: none;
				-webkit-user-select: none;
			}

			.game-controls {
				margin-top: 18px;
				text-align: center;
				color: #555;
				font-size: 12px;
				letter-spacing: 0.3px;
				line-height: 1.7;
			}

			@media (max-width: 768px) {
				.wrap {
					padding: 48px 24px 60px;
				}

				.project-header {
					flex-direction: column;
					align-items: center;
					text-align: center;
					gap: 28px;
				}

				.project-title { font-size: 48px; letter-spacing: -2px; }
				.project-description { max-width: 100%; }
			}

			@media (max-width: 480px) {
				.project-title { font-size: 40px; }
			}
		</style>
	</head>
	<body>
		<main class="wrap" role="main">
			<header class="project-header">
				<div>
					<h1 class="project-title">SARAH<br />JUMPS</h1>
					<p class="project-subtitle">Browser Game</p>
					<p class="project-description">
						A Doodle Jump-inspired game built in 2024 to explore the then-new power of AI-assisted development.
					</p>
				</div>
				<a href="/" class="back-link" tabindex="0" aria-label="Back to homepage" data-umami-event="link_click" data-umami-event-area="navigation" data-umami-event-label="home">← Back to homepage</a>
			</header>

			<hr class="rule" />

			<section>
				<span class="section-label">Play</span>
				<div class="game-container">
					<div class="game-window">
						<canvas id="gameCanvas" class="game-canvas" width="400" height="600"></canvas>
					</div>
				</div>

				<div class="game-controls">
					<p id="controls-text">Loading controls...</p>
				</div>
			</section>
		</main>

		<script>
			// Import the game
			import { SarahJumps } from '../../games/sarah-jumps/js/SarahJumps';

			// Initialize the game when the DOM is loaded
			document.addEventListener('DOMContentLoaded', () => {
				const game = new SarahJumps('gameCanvas');
				game.start();

				// Update controls text based on device type
				const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent) || window.matchMedia('(pointer: coarse)').matches;
				const controlsText = document.getElementById('controls-text');
				if (controlsText) {
					if (isMobile) {
						controlsText.innerHTML = 'Touch left or right to move<br>Tap to start/restart the game';
					} else {
						controlsText.innerHTML = 'Use arrow keys or A/D to move left/right<br>Press Space to start/restart the game';
					}
				}

				// Clean up when the page is unloaded
				window.addEventListener('unload', () => {
					game.cleanup();
				});
			});
		</script>
	</body>
</html>
