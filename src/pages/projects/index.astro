---
import UmamiAnalytics from '../../components/UmamiAnalytics.astro';
import SocialPreview from '../../components/SocialPreview.astro';
import { projects } from '../../data/projects';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Projects | Noah Eisen</title>
		<SocialPreview
			title="Noah Eisen - Projects"
			description="A catalog of my side projects, games, and web experiments."
			path="/projects/"
		/>
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300;1,9..40,400&display=swap" rel="stylesheet" />
		<UmamiAnalytics />
		<style>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			html, body { min-height: 100%; }

			body {
				background: #0a0a0a;
				font-family: 'DM Sans', sans-serif;
				color: #e2dfd8;
				-webkit-font-smoothing: antialiased;
			}

			.wrap {
				max-width: 920px;
				margin: 0 auto;
				padding: 52px 44px 80px;
			}

			.back-link {
				font-size: 11px;
				color: #666;
				text-decoration: none;
				letter-spacing: 1px;
				text-transform: uppercase;
				display: inline-flex;
				align-items: center;
				gap: 8px;
				margin-bottom: 28px;
				transition: color 0.15s;
			}

			.back-link:hover { color: #999; }

			.page-title {
				font-size: 48px;
				font-weight: 700;
				letter-spacing: -1.5px;
				margin: 0 0 10px;
				color: #eae7e0;
				line-height: 1;
			}

			.page-desc {
				font-size: 14px;
				color: #777;
				margin: 0;
				line-height: 1.7;
				max-width: 540px;
			}

			.section-label {
				font-size: 10px;
				letter-spacing: 4px;
				text-transform: uppercase;
				color: #444;
				display: block;
				margin-top: 52px;
				margin-bottom: 20px;
				padding-bottom: 16px;
				border-bottom: 1px solid #1a1a1a;
			}

			.projects-list {
				display: flex;
				flex-direction: column;
				border-top: 1px solid #1a1a1a;
			}

			.project-entry {
				text-decoration: none;
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 30px;
				align-items: center;
				color: inherit;
				padding: 30px 0;
				border-bottom: 1px solid #1a1a1a;
			}

			.project-entry:nth-child(even) .project-visual {
				order: 2;
			}

			.project-visual {
				aspect-ratio: 16 / 9;
				min-height: 170px;
				background:
					linear-gradient(135deg, color-mix(in srgb, var(--project-accent) 22%, #111), #0f0f0f 58%),
					repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.04) 0 1px, transparent 1px 18px);
				border: 1px solid #1c1c1c;
				border-radius: 6px;
				overflow: hidden;
				position: relative;
				display: flex;
				align-items: flex-end;
				padding: 22px;
				transition: border-color 0.15s, transform 0.15s;
			}

			.project-entry:hover .project-visual,
			.project-entry:focus-visible .project-visual {
				border-color: #2f2f2f;
				transform: translateY(-2px);
			}

			.project-image {
				position: absolute;
				inset: 0;
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			.project-visual-mark {
				position: relative;
				z-index: 1;
				font-size: 11px;
				color: color-mix(in srgb, var(--project-accent) 65%, #e2dfd8);
				font-weight: 600;
				letter-spacing: 2px;
				text-transform: uppercase;
			}

			.project-body {
				max-width: 360px;
				padding-left: 20px;
				border-left: 2px solid color-mix(in srgb, var(--project-accent) 55%, #222);
			}

			.project-entry:nth-child(even) .project-body {
				justify-self: end;
				text-align: right;
				padding-left: 0;
				padding-right: 20px;
				border-left: 0;
				border-right: 2px solid color-mix(in srgb, var(--project-accent) 55%, #222);
			}

			.project-title {
				font-size: 28px;
				font-weight: 700;
				letter-spacing: 0;
				line-height: 1.05;
				color: #eae7e0;
				margin-bottom: 12px;
			}

			.project-desc {
				font-size: 14px;
				color: #777;
				line-height: 1.7;
				margin-bottom: 18px;
			}

			.project-link {
				font-size: 12px;
				color: var(--project-accent);
				font-weight: 600;
				letter-spacing: 1px;
				text-transform: uppercase;
			}

			@media (max-width: 768px) {
				.wrap { padding: 36px 24px 60px; }
				.page-title { font-size: 36px; }

				.projects-list {
					gap: 38px;
				}

				.project-entry {
					grid-template-columns: 1fr;
					gap: 18px;
					padding: 28px 0;
				}

				.project-entry:nth-child(even) .project-visual {
					order: 0;
				}

				.project-visual {
					min-height: 190px;
				}

				.project-body {
					max-width: 100%;
				}

				.project-entry:nth-child(even) .project-body {
					justify-self: stretch;
					text-align: left;
					padding-left: 20px;
					padding-right: 0;
					border-left: 2px solid color-mix(in srgb, var(--project-accent) 55%, #222);
					border-right: 0;
				}

				.project-title {
					font-size: 24px;
				}
			}
		</style>
	</head>
	<body>
		<main class="wrap">
			<div>
				<a href="/" class="back-link" data-umami-event="link_click" data-umami-event-area="navigation" data-umami-event-label="home">&larr; Back to Noah Eisen</a>
				<h1 class="page-title">Projects</h1>
				<p class="page-desc">A catalog of my side projects, games, and web experiments.</p>
			</div>

			<section>
				<span class="section-label">All Projects</span>
				<div class="projects-list">
					{projects.map((project) => (
						<a
							href={project.href}
							class="project-entry"
							style={`--project-accent: ${project.accent}`}
							target={project.external ? '_blank' : undefined}
							rel={project.external ? 'noopener noreferrer' : undefined}
							data-umami-event="link_click"
							data-umami-event-area="projects"
							data-umami-event-label={project.label}
						>
							<div class="project-visual">
								{project.image && (
									<img src={project.image} alt="" class="project-image" loading="lazy" />
								)}
								<span class="project-visual-mark">{project.visualLabel}</span>
							</div>
							<div class="project-body">
								<h2 class="project-title">{project.title}</h2>
								<p class="project-desc">{project.description}</p>
								<span class="project-link">{project.external ? 'Visit project' : 'View project'} &rarr;</span>
							</div>
						</a>
					))}
				</div>
			</section>
		</main>
	</body>
</html>
