			<script id="inference-data" type="application/json" set:html={JSON.stringify(inferenceExamples)}></script>
		</main>

		<script>
			const steps = Array.from(document.querySelectorAll('[data-corpus-step]'));
			const stages = Array.from(document.querySelectorAll('[data-stage]'));
			const revealToggles = Array.from(document.querySelectorAll('[data-reveal-toggle]'));
			const tokenExampleToggles = Array.from(document.querySelectorAll('[data-token-example-toggle]'));
			const tokenExamplePanels = Array.from(document.querySelectorAll('[data-token-example-panel]'));

			const setActiveStep = (activeId) => {
				steps.forEach((step) => {
					step.classList.toggle('is-active', step.dataset.corpusStep === activeId);
				});

				stages.forEach((stage) => {
					stage.classList.toggle('is-active', stage.dataset.stage === activeId);
				});
			};

			if ('IntersectionObserver' in window && steps.length > 0) {
				const observer = new IntersectionObserver((entries) => {
					const visibleEntry = entries
						.filter((entry) => entry.isIntersecting)
						.sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

					if (visibleEntry instanceof IntersectionObserverEntry) {
						setActiveStep(visibleEntry.target.dataset.corpusStep);
					}
				}, {
					rootMargin: '-28% 0px -38% 0px',
					threshold: [0.2, 0.45, 0.7],
				});

				steps.forEach((step) => observer.observe(step));
			}

			revealToggles.forEach((toggle) => {
				toggle.addEventListener('click', () => {
					const panelId = toggle.getAttribute('data-reveal-toggle');
					if (!panelId) return;

					const panel = document.getElementById(panelId);
					const isVisible = panel?.classList.toggle('is-visible') ?? false;
					toggle.setAttribute('aria-expanded', String(isVisible));
					toggle.textContent = isVisible
						? toggle.textContent?.replace('Show', 'Hide') ?? ''
						: toggle.textContent?.replace('Hide', 'Show') ?? '';
				});
			});

			const setTokenExample = (exampleId) => {
				tokenExampleToggles.forEach((toggle) => {
					const isActive = toggle.getAttribute('data-token-example-toggle') === exampleId;
					toggle.classList.toggle('is-active', isActive);
					toggle.setAttribute('aria-pressed', String(isActive));
				});

				tokenExamplePanels.forEach((panel) => {
					panel.classList.toggle('is-active', panel.getAttribute('data-token-example-panel') === exampleId);
				});
			};

			tokenExampleToggles.forEach((toggle) => {
				toggle.addEventListener('click', () => {
					const exampleId = toggle.getAttribute('data-token-example-toggle');
					if (!exampleId) return;

					setTokenExample(exampleId);
				});
			});

			const trainingStep = document.querySelector('[data-training-step]');
			const trainingReset = document.querySelector('[data-training-reset]');
			const trainingVisual = document.querySelector('[data-training-visual]');
			const trainingExampleToggles = Array.from(document.querySelectorAll('[data-training-example-toggle]'));
			const trainingExamplePanels = Array.from(document.querySelectorAll('[data-training-example-panel]'));
			const weightsReplay = document.querySelector('[data-weights-replay]');
			const weightsReset = document.querySelector('[data-weights-reset]');
			const weightsVisual = document.querySelector('[data-weights-visual]');
			const weightNeedles = Array.from(document.querySelectorAll('.weight-needle'));
			const parisProbability = document.querySelector('[data-weight-probability="paris"]');
			const franceProbability = document.querySelector('[data-weight-probability="france"]');
			let parisProbabilityValue = 80;
			const inferenceDataElement = document.getElementById('inference-data');
			const inferenceData = inferenceDataElement?.textContent ? JSON.parse(inferenceDataElement.textContent) : [];
			const inferenceExampleToggles = Array.from(document.querySelectorAll('[data-inference-example-toggle]'));
			const inferenceVisual = document.querySelector('[data-inference-visual]');
			const inferenceNext = document.querySelector('[data-inference-next]');
			const inferenceReset = document.querySelector('[data-inference-reset]');
			const inferenceContextBase = document.querySelector('[data-inference-context-base]');
			const inferenceContextGenerated = document.querySelector('[data-inference-context-generated]');
			const inferenceCandidates = document.querySelector('[data-inference-candidates]');
			const inferenceSampled = document.querySelector('[data-inference-sampled]');
			const inferenceOutput = document.querySelector('[data-inference-output]');
			const inferenceStepCount = document.querySelector('[data-inference-step-count]');
			const inferenceMovingToken = document.querySelector('[data-inference-moving-token]');
			const inferenceCandidateColors = ['#8f9f86', '#d6a561', '#84a6d8'];
			const inferencePhases = ['context', 'neuralNet', 'map', 'choice', 'append'];
			const inferencePhaseClasses = {
				context: 'is-context-active',
				neuralNet: 'is-net-active',
				map: 'is-map-active',
				choice: 'is-choice-active',
				append: 'is-append-active',
			};
			const inferencePhaseLabels = {
				context: 'Current context',
				neuralNet: 'Neural net',
				map: 'Probability map',
				choice: 'Sampled choice',
				append: 'Append token',
			};
			let activeInferenceId = 'capital';
			let inferenceTokenIndex = 0;
			let inferencePhaseIndex = -1;
			let toastRunIndex = 0;

			const getActiveTrainingPanel = () => {
				return trainingExamplePanels.find((panel) => panel.classList.contains('is-active'));
			};

			const getTrainingCandidates = () => {
				const activePanel = getActiveTrainingPanel();
				return Array.from(activePanel?.querySelectorAll('[data-training-candidate]') ?? []);
			};

			const setTrainingCandidateProbability = (candidate, value) => {
				if (!(candidate instanceof HTMLElement)) return;

				const roundedValue = Math.round(value);
				candidate.dataset.trainingProbability = String(roundedValue);
				candidate.style.setProperty('--probability-width', `${Math.min(92, Math.max(8, roundedValue))}%`);

				const valueElement = candidate.querySelector('.probability-value');
				if (valueElement instanceof HTMLElement) {
					valueElement.textContent = `${roundedValue}%`;
				}
			};

			const resetActiveTrainingProbabilities = () => {
				getTrainingCandidates().forEach((candidate) => {
					if (!(candidate instanceof HTMLElement)) return;

					const initialValue = Number(candidate.getAttribute('data-training-initial-probability') ?? candidate.dataset.trainingProbability ?? 0);
					setTrainingCandidateProbability(candidate, initialValue);
				});
			};

			document.querySelectorAll('[data-training-candidate]').forEach((candidate) => {
				if (!(candidate instanceof HTMLElement)) return;

				candidate.setAttribute('data-training-initial-probability', candidate.dataset.trainingProbability ?? '0');
			});

			const setWeightProbability = (parisValue, franceValue) => {
				if (parisProbability instanceof HTMLElement) {
					parisProbability.textContent = `${parisValue}%`;
					parisProbability.closest('.mini-probability-row')?.style.setProperty('--mini-probability-width', `${parisValue}%`);
				}

				if (franceProbability instanceof HTMLElement) {
					franceProbability.textContent = `${franceValue}%`;
					franceProbability.closest('.mini-probability-row')?.style.setProperty('--mini-probability-width', `${franceValue}%`);
				}
			};

			const replayTrainingAnimation = () => {
				trainingVisual?.classList.remove('is-animating');

				if (trainingVisual instanceof HTMLElement) {
					void trainingVisual.offsetWidth;
				}

				window.requestAnimationFrame(() => {
					trainingVisual?.classList.add('is-animating');
				});
			};

			const setTrainingExample = (exampleId) => {
				trainingExampleToggles.forEach((toggle) => {
					const isActive = toggle.getAttribute('data-training-example-toggle') === exampleId;
					toggle.classList.toggle('is-active', isActive);
					toggle.setAttribute('aria-pressed', String(isActive));
				});

				trainingExamplePanels.forEach((panel) => {
					panel.classList.toggle('is-active', panel.getAttribute('data-training-example-panel') === exampleId);
				});

				resetActiveTrainingProbabilities();
			};

			trainingExampleToggles.forEach((toggle) => {
				toggle.addEventListener('click', () => {
					const exampleId = toggle.getAttribute('data-training-example-toggle');
					if (!exampleId) return;

					setTrainingExample(exampleId);
					replayTrainingAnimation();
				});
			});

			trainingStep?.addEventListener('click', () => {
				const candidates = getTrainingCandidates();
				if (candidates.length === 0) return;

				candidates.forEach((candidate) => {
					if (!(candidate instanceof HTMLElement)) return;

					const currentValue = Number(candidate.dataset.trainingProbability ?? 0);
					const nextValue = candidate.dataset.trainingCorrect === 'true'
						? Math.min(96, currentValue + 8)
						: Math.max(1, currentValue - 4);
					setTrainingCandidateProbability(candidate, nextValue);
				});

				replayTrainingAnimation();
			});

			trainingReset?.addEventListener('click', () => {
				resetActiveTrainingProbabilities();
				replayTrainingAnimation();
			});

			const replayWeightsAnimation = () => {
				weightsVisual?.classList.remove('is-tuning');

				weightNeedles.forEach((needle) => {
					if (!(needle instanceof HTMLElement)) return;

					const currentAngle = Number(needle.dataset.knobAngle ?? 0);
					const nextAngle = Math.round(Math.random() * 116) - 58;
					needle.style.setProperty('--knob-start', `${currentAngle}deg`);
					needle.style.setProperty('--knob-end', `${nextAngle}deg`);
					needle.style.setProperty('--knob-delay', `${Math.random() * 0.28}s`);
					needle.dataset.knobAngle = String(nextAngle);
				});

				parisProbabilityValue = Math.min(98, parisProbabilityValue + 4);
				const franceProbabilityValue = Math.max(1, 100 - parisProbabilityValue - 2);
				setWeightProbability(parisProbabilityValue, franceProbabilityValue);

				if (weightsVisual instanceof HTMLElement) {
					void weightsVisual.offsetWidth;
				}

				window.requestAnimationFrame(() => {
					weightsVisual?.classList.add('is-tuning');
				});
			};

			weightsReplay?.addEventListener('click', () => {
				replayWeightsAnimation();
			});

			weightsReset?.addEventListener('click', () => {
				weightsVisual?.classList.remove('is-tuning');
				parisProbabilityValue = 80;
				setWeightProbability(80, 18);

				weightNeedles.forEach((needle) => {
					if (!(needle instanceof HTMLElement)) return;

					const initialAngle = Number(needle.getAttribute('data-knob-initial') ?? 0);
					needle.dataset.knobAngle = String(initialAngle);
					needle.style.setProperty('--knob-start', `${initialAngle}deg`);
					needle.style.setProperty('--knob-end', `${initialAngle}deg`);
				});
			});

			const getActiveInferenceExample = () => {
				return inferenceData.find((example) => example.id === activeInferenceId) ?? inferenceData[0];
			};

			const getActiveInferenceRun = (example) => {
				const runIndex = example?.id === 'toast' ? toastRunIndex : 0;
				return example?.runs?.[runIndex] ?? example?.runs?.[0];
			};

			const getGeneratedSample = (run, tokenCount) => {
				if (!run || tokenCount <= 0) return '';

				return run.steps
					.slice(0, tokenCount)
					.map((step) => step.sample)
					.join('');
			};

			const getInferencePhase = () => {
				return inferencePhases[inferencePhaseIndex] ?? 'idle';
			};

			const getCompletedInferenceTokenCount = (run) => {
				if (!run) return 0;

				const shouldIncludeCurrentToken = getInferencePhase() === 'append';
				const tokenCount = shouldIncludeCurrentToken ? inferenceTokenIndex + 1 : inferenceTokenIndex;
				return Math.min(tokenCount, run.steps.length);
			};

			const renderInferenceCandidates = (step, shouldShowMap, shouldHighlightSelection) => {
				if (!(inferenceCandidates instanceof HTMLElement)) return;

				if (!step || !shouldShowMap) {
					inferenceCandidates.replaceChildren();
					return;
				}

				const rows = step.candidates.map((candidate, index) => {
					const row = document.createElement('div');
					row.className = 'mini-probability-row';
					row.classList.toggle('is-selected', Boolean(shouldHighlightSelection && candidate.selected));
					row.style.setProperty('--mini-probability-width', `${candidate.probability}%`);
					row.style.setProperty('--mini-probability-accent', inferenceCandidateColors[index % inferenceCandidateColors.length]);

					const label = document.createElement('span');
					label.textContent = candidate.label;

					const probability = document.createElement('span');
					probability.className = 'mini-probability-value';
					probability.textContent = `${candidate.probability}%`;

					row.append(label, probability);
					return row;
				});

				inferenceCandidates.replaceChildren(...rows);
			};

			const renderInferencePhase = (phase) => {
				if (!(inferenceVisual instanceof HTMLElement)) return;

				Object.values(inferencePhaseClasses).forEach((className) => {
					inferenceVisual.classList.remove(className);
				});

				const activeClass = inferencePhaseClasses[phase];
				if (activeClass) {
					inferenceVisual.classList.add(activeClass);
				}
			};

			const renderInference = () => {
				const example = getActiveInferenceExample();
				const run = getActiveInferenceRun(example);
				if (!example || !run) return;

				const phase = getInferencePhase();
				const activeStep = run.steps[Math.min(inferenceTokenIndex, run.steps.length - 1)];
				const completedTokenCount = getCompletedInferenceTokenCount(run);
				const generatedSample = getGeneratedSample(run, completedTokenCount);
				const shouldShowMap = ['map', 'choice', 'append'].includes(phase);
				const shouldHighlightSelection = ['choice', 'append'].includes(phase);
				const isAppending = phase === 'append';
				const isComplete = inferenceTokenIndex >= run.steps.length - 1 && isAppending;

				renderInferencePhase(phase);

				if (inferenceContextBase instanceof HTMLElement) {
					inferenceContextBase.textContent = example.initialContext;
				}

				if (inferenceContextGenerated instanceof HTMLElement) {
					inferenceContextGenerated.textContent = generatedSample;
					inferenceContextGenerated.classList.toggle('is-appending', isAppending);
				}

				if (inferenceOutput instanceof HTMLElement) {
					inferenceOutput.textContent = generatedSample
						? `${example.initialContext}${generatedSample}`
						: example.emptyGenerated;
					inferenceOutput.classList.toggle('is-appending', isAppending);
				}

				if (inferenceStepCount instanceof HTMLElement) {
					inferenceStepCount.textContent = inferencePhaseIndex >= 0
						? `${inferencePhaseLabels[phase] ?? 'Sampling'} ${inferenceTokenIndex + 1} of ${run.steps.length}`
						: 'Ready to sample';
				}

				if (inferenceSampled instanceof HTMLElement) {
					const sampledValue = shouldHighlightSelection ? activeStep.label : 'waiting';
					inferenceSampled.textContent = `Sampled token: ${sampledValue}`;
				}

				if (inferenceMovingToken instanceof HTMLElement) {
					inferenceMovingToken.textContent = isAppending ? activeStep.label : '';
				}

				renderInferenceCandidates(activeStep, shouldShowMap, shouldHighlightSelection);

				if (inferenceNext instanceof HTMLButtonElement) {
					inferenceNext.disabled = isComplete;
				}
			};

			const setInferenceExample = (exampleId) => {
				activeInferenceId = exampleId;
				inferenceTokenIndex = 0;
				inferencePhaseIndex = -1;

				inferenceExampleToggles.forEach((toggle) => {
					const isActive = toggle.getAttribute('data-inference-example-toggle') === exampleId;
					toggle.classList.toggle('is-active', isActive);
					toggle.setAttribute('aria-pressed', String(isActive));
				});

				renderInference();
			};

			inferenceExampleToggles.forEach((toggle) => {
				toggle.addEventListener('click', () => {
					const exampleId = toggle.getAttribute('data-inference-example-toggle');
					if (!exampleId) return;

					setInferenceExample(exampleId);
				});
			});

			inferenceNext?.addEventListener('click', () => {
				const example = getActiveInferenceExample();
				const run = getActiveInferenceRun(example);
				if (!run) return;

				const isComplete = inferenceTokenIndex >= run.steps.length - 1 && getInferencePhase() === 'append';
				if (isComplete) return;

				if (inferencePhaseIndex < inferencePhases.length - 1) {
					inferencePhaseIndex += 1;
				} else {
					inferenceTokenIndex = Math.min(inferenceTokenIndex + 1, run.steps.length - 1);
					inferencePhaseIndex = 0;
				}

				renderInference();
			});

			inferenceReset?.addEventListener('click', () => {
				const example = getActiveInferenceExample();
				if (example?.id === 'toast') {
					toastRunIndex = (toastRunIndex + 1) % example.runs.length;
				}

				inferenceTokenIndex = 0;
				inferencePhaseIndex = -1;
				renderInference();
			});

			renderInference();
		</script>
	</body>
</html>
