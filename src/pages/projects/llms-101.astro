---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>LLMs 101 | Noah Eisen</title>
		<SocialPreview
			title="Noah Eisen - LLMs 101"
			description="An interactive, non-technical talk about how large language models are built."
			path="/projects/llms-101/"
		/>
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300;1,9..40,400&display=swap" rel="stylesheet" />
		<UmamiAnalytics />
		<style>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			html, body { min-height: 100%; }
			html { scroll-behavior: smooth; }

			body {
				--llms-accent: #84a6d8;
				--llms-accent-warm: #d6a561;
				--llms-accent-green: #8f9f86;
				background: #0a0a0a;
				font-family: 'DM Sans', sans-serif;
				color: #e2dfd8;
				-webkit-font-smoothing: antialiased;
			}

			a {
				color: inherit;
			}

			.wrap {
				max-width: 1240px;
				margin: 0 auto;
				padding: 72px 44px 92px;
			}

			.project-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				gap: 40px;
			}

			.header-copy {
				max-width: 680px;
			}

			.project-title {
				font-size: 76px;
				font-weight: 700;
				letter-spacing: 0;
				line-height: 0.92;
				margin: 0 0 20px;
				color: #eae7e0;
			}

			.project-subtitle {
				font-size: 13px;
				color: var(--llms-accent);
				margin: 0 0 18px;
				letter-spacing: 2px;
				text-transform: uppercase;
			}

			.project-description {
				font-size: 15px;
				color: #aaa49a;
				margin: 0;
				max-width: 600px;
				line-height: 1.75;
			}

			.back-link {
				display: inline-block;
				color: #5b8ef0;
				text-decoration: none;
				font-size: 13px;
				font-weight: 500;
				letter-spacing: 0.3px;
				white-space: nowrap;
				transition: opacity 0.15s;
			}

			.back-link:hover { opacity: 0.8; }

			.rule {
				border: none;
				border-top: 1px solid #1e1e1e;
				margin: 56px 0;
			}

			.intro-grid {
				display: grid;
				grid-template-columns: minmax(0, 0.9fr) minmax(440px, 1.1fr);
				gap: 56px;
				align-items: start;
			}

			.section-label {
				font-size: 10px;
				letter-spacing: 4px;
				text-transform: uppercase;
				color: #444;
				margin-bottom: 24px;
				display: block;
			}

			.promise {
				font-size: 32px;
				font-weight: 700;
				line-height: 1.15;
				color: #eae7e0;
				max-width: 620px;
				margin-bottom: 16px;
			}

			.body-copy {
				color: #888;
				font-size: 14px;
				line-height: 1.8;
				max-width: 620px;
			}

			.body-copy--short {
				max-width: 500px;
			}

			.source-link {
				margin-top: 24px;
				display: inline-flex;
				align-items: center;
				gap: 8px;
				color: var(--llms-accent);
				font-size: 12px;
				font-weight: 600;
				letter-spacing: 1px;
				text-decoration: none;
				text-transform: uppercase;
			}

			.source-link:hover { opacity: 0.82; }

			.corpus-actions {
				display: flex;
				flex-wrap: wrap;
				justify-content: flex-start;
				align-items: center;
				gap: 14px;
				margin-top: 28px;
			}

			.corpus-actions .source-link,
			.corpus-actions .reveal-button {
				margin-top: 0;
			}

			.reveal-button {
				margin-top: 24px;
				border: 1px solid color-mix(in srgb, var(--llms-accent) 46%, #252525);
				border-radius: 999px;
				background: #101010;
				color: #eae7e0;
				cursor: pointer;
				font-family: inherit;
				font-size: 12px;
				font-weight: 700;
				letter-spacing: 1px;
				line-height: 1;
				padding: 12px 16px;
				text-transform: uppercase;
				transition: border-color 0.15s, transform 0.15s, color 0.15s;
			}

			.reveal-button:hover,
			.reveal-button:focus-visible {
				border-color: var(--llms-accent);
				color: var(--llms-accent);
				transform: translateY(-1px);
			}

			.reveal-panel {
				display: none;
			}

			.reveal-panel.is-visible {
				display: block;
			}

			.goal-list {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 10px;
			}

			.goal-chip {
				min-height: 96px;
				border: 1px solid #1c1c1c;
				border-left: 2px solid color-mix(in srgb, var(--goal-accent) 60%, #222);
				border-radius: 6px;
				padding: 18px 18px;
				background: #101010;
			}

			.goal-term {
				display: block;
				color: #eae7e0;
				font-size: 22px;
				font-weight: 700;
				line-height: 1.1;
				margin-bottom: 8px;
			}

			.goal-desc {
				display: block;
				color: #6f6f6f;
				font-size: 12px;
				line-height: 1.45;
			}

			.corpus-layout {
				display: grid;
				grid-template-columns: minmax(340px, 0.8fr) minmax(520px, 1.2fr);
				gap: 56px;
				align-items: start;
			}

			.corpus-intro {
				position: sticky;
				top: 28px;
			}

			.pipeline-panel {
				border: 1px solid #1c1c1c;
				border-radius: 6px;
				background:
					linear-gradient(135deg, color-mix(in srgb, var(--llms-accent) 18%, #111), #0f0f0f 54%),
					repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.035) 0 1px, transparent 1px 18px);
				min-height: 0;
				padding: 26px;
				margin-top: 24px;
				position: relative;
				overflow: hidden;
				box-shadow: 0 24px 70px rgba(0, 0, 0, 0.26);
			}

			.pipeline-title {
				font-size: 12px;
				color: #6f6f6f;
				letter-spacing: 2px;
				text-transform: uppercase;
				margin-bottom: 30px;
			}

			.pipeline {
				display: grid;
				grid-template-columns: 1fr;
				gap: 8px;
			}

			.pipeline-node {
				min-height: 64px;
				border: 1px solid rgba(226, 223, 216, 0.16);
				border-radius: 6px;
				padding: 13px 15px;
				background: rgba(10, 10, 10, 0.42);
				transition: border-color 0.18s ease, background-color 0.18s ease, transform 0.18s ease;
			}

			.pipeline-node.is-active {
				border-color: color-mix(in srgb, var(--node-accent) 72%, #e2dfd8);
				background: color-mix(in srgb, var(--node-accent) 18%, rgba(10, 10, 10, 0.5));
				transform: translateY(-2px);
			}

			.pipeline-arrow {
				color: #3c3c3c;
				text-align: center;
				font-size: 18px;
				line-height: 1;
				transform: rotate(90deg);
			}

			.pipeline-node-label {
				display: block;
				color: #eae7e0;
				font-size: 16px;
				font-weight: 700;
				line-height: 1.1;
				margin-bottom: 10px;
			}

			.pipeline-node-copy {
				color: #777;
				font-size: 12px;
				line-height: 1.55;
			}

			.example-thread {
				margin-top: 18px;
				border: 1px solid #1c1c1c;
				border-radius: 6px;
				background:
					linear-gradient(135deg, color-mix(in srgb, var(--llms-accent) 10%, #111), #0f0f0f 58%),
					repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.025) 0 1px, transparent 1px 18px);
				padding: 20px;
			}

			.example-thread-title {
				color: #666;
				font-size: 10px;
				font-weight: 700;
				letter-spacing: 1.8px;
				text-transform: uppercase;
				margin-bottom: 12px;
			}

			.example-source-list {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 14px;
			}

			.example-source {
				border: 1px solid #1c1c1c;
				border-radius: 6px;
				background: #f3f0e8;
				color: #eae7e0;
				line-height: 1.35;
				overflow: hidden;
				box-shadow: 0 20px 52px rgba(0, 0, 0, 0.24);
			}

			.example-browser-bar {
