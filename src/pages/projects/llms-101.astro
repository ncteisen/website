const buildDocumentHtml = (example: typeof throughlineExamples[number]) => {
	const escapeHtml = (value: string) => {
		return value
			.replaceAll('&', '&amp;')
			.replaceAll('<', '&lt;')
			.replaceAll('>', '&gt;')
			.replaceAll('"', '&quot;')
			.replaceAll("'", '&#39;');
	};
	const openTag = (tag: string) => `<span class="html-punctuation">&lt;</span><span class="html-tag-name">${tag}</span><span class="html-punctuation">&gt;</span>`;
	const closeTag = (tag: string) => `<span class="html-punctuation">&lt;/</span><span class="html-tag-name">${tag}</span><span class="html-punctuation">&gt;</span>`;

	const paragraphLines = example.documentParagraphs
		.map((paragraph) => `  ${openTag('p')}<span class="html-text">${escapeHtml(paragraph)}</span>${closeTag('p')}`)
		.join('\n');

	return [
		openTag('article'),
		`  ${openTag('h1')}<span class="html-text">${escapeHtml(example.documentTitle)}</span>${closeTag('h1')}`,
		paragraphLines,
		closeTag('article'),
	].join('\n');
};

const getDocumentExcerpt = (example: typeof throughlineExamples[number]) => {
	return `${example.documentParagraphs.join(' ').slice(0, 118)}...`;
};
