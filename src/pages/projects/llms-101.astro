			@keyframes inference-append-pop {
				0% {
					filter: brightness(1.35);
				}

				100% {
					filter: brightness(1);
				}
			}

			@keyframes inference-token-move {
				0% {
					opacity: 0;
					transform: translate(120px, -8px) scale(0.96);
				}

				24% {
					opacity: 1;
				}

				78% {
					opacity: 1;
				}

				100% {
					opacity: 0;
					transform: translate(-320px, -54px) scale(1.02);
				}
			}

			.replay-button:disabled {
				cursor: default;
				opacity: 0.44;
				transform: none;
			}

			.checkpoint-section {
				width: auto;
				margin-left: 0;
				transform: none;
			}

			.checkpoint-layout {
				display: grid;
				grid-template-columns: minmax(320px, 0.72fr) minmax(560px, 1.28fr);
				gap: 56px;
				align-items: start;
			}

			.checkpoint-list {
				border-top: 1px solid #1a1a1a;
				color: #999;
				font-size: 15px;
				line-height: 1.65;
				list-style: none;
			}

			.checkpoint-list li {
				border-bottom: 1px solid #1a1a1a;
				padding: 14px 0 14px 20px;
				position: relative;
			}

			.checkpoint-list li::before {
				content: '';
				position: absolute;
				left: 0;
				top: 25px;
				width: 5px;
				height: 5px;
				border-radius: 999px;
				background: var(--llms-accent);
			}

			.demo-note {
				margin-top: 18px;
				border-left: 2px solid color-mix(in srgb, #d6a561 60%, #222);
				color: #999;
				font-size: 13px;
				line-height: 1.6;
				padding-left: 14px;
			}

			@keyframes train-reveal {
				0% {
					opacity: 0.2;
					transform: translateY(10px) scale(0.98);
				}

				100% {
					opacity: 1;
					transform: translateY(0) scale(1);
				}
			}

			@keyframes tune-knob {
				0% {
					transform: translate(-50%, -96%) rotate(var(--knob-start));
				}

				46% {
					transform: translate(-50%, -96%) rotate(calc(var(--knob-end) + 18deg));
				}

				100% {
					transform: translate(-50%, -96%) rotate(var(--knob-end));
				}
			}

			@media (max-width: 840px) {
				.wrap {
					padding: 48px 24px 68px;
				}

				.project-header {
					flex-direction: column;
					align-items: center;
					text-align: center;
					gap: 28px;
				}

				.project-title {
					font-size: 48px;
				}

				.project-description {
					max-width: 100%;
