			}

			.inference-visual:not(.is-map-active):not(.is-choice-active):not(.is-append-active) [data-inference-candidates],
			.inference-visual:not(.is-map-active):not(.is-choice-active):not(.is-append-active) [data-inference-sampled] {
				opacity: 0;
				visibility: hidden;
			}

			.inference-step-count {
				color: #777;
				font-size: 11px;
				font-weight: 700;
				letter-spacing: 1.4px;
				margin: -6px 0 16px;
				text-transform: uppercase;
			}

			.inference-candidate {
				border: 1px solid #1c1c1c;
				border-radius: 6px;
				background: rgba(10, 10, 10, 0.38);
				color: #eae7e0;
				font-size: 14px;
				font-weight: 700;
				line-height: 1.25;
				min-height: 54px;
				padding: 9px 16px;
				position: relative;
				overflow: hidden;
