			.inference-candidate::before {
				display: none;
			}

			.inference-candidate.is-selected {
				border-color: color-mix(in srgb, #8f9f86 70%, #e2dfd8);
				background: color-mix(in srgb, #8f9f86 13%, rgba(10, 10, 10, 0.42));
			}

			.inference-candidate-content {
				position: relative;
				display: grid;
				grid-template-columns: minmax(0, 1fr) auto;
				gap: 16px;
				align-items: center;
				min-height: 34px;
			}

			.inference-candidate-token,
