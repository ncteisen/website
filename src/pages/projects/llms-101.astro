													>
														Example {index + 1}
													</button>
												))}
											</div>
											{throughlineExamples.map((example, index) => (
												<div
													class={`corpus-example-panel${index === 0 ? ' is-active' : ''}`}
													data-corpus-example-panel="text"
													data-corpus-example-id={example.id}
												>
													<pre class="plaintext-example-block">{example.documentParagraphs.join('\n\n')}</pre>
												</div>
											))}
										</div>
									</details>
								</div>
							</article>

							<article class="document-stage" style="--stage-accent: #b28ad6">
								<div>
									<p class="document-stage-label">Step 5</p>
									<h3 class="document-stage-title">Filter and deduplicate</h3>
								</div>
								<div>
									<p class="document-stage-copy">More passes remove boilerplate, normalize text, reduce near-copies, and drop low-value content.</p>
								</div>
							</article>

							<article class="document-stage" style="--stage-accent: #84a6d8">
								<div>
									<p class="document-stage-label">Step 6</p>
									<h3 class="document-stage-title">Store a corpus row</h3>
