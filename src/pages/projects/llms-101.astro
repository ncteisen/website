					rgba(10, 10, 10, 0.42);
				box-shadow: 0 0 0 1px color-mix(in srgb, var(--llms-accent) 18%, transparent);
			}

			.inference-visual.is-net-active [data-inference-net] {
				color: #eae7e0;
				transform: translateY(-2px);
			}

			.inference-visual.is-net-active [data-inference-net] .neural-net-box {
