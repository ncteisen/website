				display: block;
			}

			.inference-candidate-score {
				align-self: center;
			}

			.inference-candidate-kicker {
				display: none;
			}

			.inference-candidate-label {
				color: #eae7e0;
				display: block;
				font-size: 16px;
				line-height: 1.25;
				min-width: 0;
			}

			.inference-candidate-probability {
				border: 1px solid color-mix(in srgb, var(--inference-probability-accent) 48%, #252525);
				border-radius: 6px;
				background: color-mix(in srgb, var(--inference-probability-accent) 12%, #101010);
				color: var(--inference-probability-accent);
				flex: 0 0 auto;
				font-size: 17px;
				font-weight: 700;
				line-height: 1;
				min-width: 60px;
				padding: 8px 10px;
				text-align: center;
			}

			.inference-candidate.is-selected .inference-candidate-content::after {
				content: 'sampled';
				border: 1px solid rgba(143, 159, 134, 0.5);
				border-radius: 999px;
				color: #b8c4ae;
				font-size: 10px;
				font-weight: 700;
				letter-spacing: 1px;
				line-height: 1;
				padding: 7px 8px;
				text-transform: uppercase;
				justify-self: end;
				grid-column: 1 / -1;
			}

			:global(.inference-candidate) {
				border: 1px solid #1c1c1c;
				border-radius: 6px;
				background: rgba(10, 10, 10, 0.38);
				color: #eae7e0;
				font-size: 14px;
				font-weight: 700;
				line-height: 1.25;
				min-height: 54px;
				padding: 9px 16px;
				position: relative;
				overflow: hidden;
			}

			:global(.inference-candidate + .inference-candidate) {
				margin-top: 10px;
			}

			:global(.inference-candidate::before) {
				display: none;
			}

			:global(.inference-candidate.is-selected) {
				border-color: color-mix(in srgb, #8f9f86 70%, #e2dfd8);
				background: color-mix(in srgb, #8f9f86 13%, rgba(10, 10, 10, 0.42));
			}

			:global(.inference-candidate-content) {
				position: relative;
				display: grid;
				grid-template-columns: minmax(0, 1fr) auto;
				gap: 16px;
				align-items: center;
				min-height: 34px;
			}

			:global(.inference-candidate-token),
			:global(.inference-candidate-score) {
				display: block;
			}

			:global(.inference-candidate-score) {
				align-self: center;
			}

			:global(.inference-candidate-kicker) {
				display: none;
			}

			:global(.inference-candidate-label) {
				color: #eae7e0;
				display: block;
				font-size: 16px;
				line-height: 1.25;
				min-width: 0;
			}

			:global(.inference-candidate-probability) {
				border: 1px solid color-mix(in srgb, var(--inference-probability-accent) 48%, #252525);
				border-radius: 6px;
				background: color-mix(in srgb, var(--inference-probability-accent) 12%, #101010);
				color: var(--inference-probability-accent);
				flex: 0 0 auto;
				font-size: 17px;
				font-weight: 700;
				line-height: 1;
				min-width: 60px;
				padding: 8px 10px;
				text-align: center;
			}

			:global(.inference-candidate.is-selected .inference-candidate-content::after) {
				content: 'sampled';
				border: 1px solid rgba(143, 159, 134, 0.5);
				border-radius: 999px;
				color: #b8c4ae;
				font-size: 10px;
				font-weight: 700;
				letter-spacing: 1px;
				line-height: 1;
				padding: 7px 8px;
				text-transform: uppercase;
				justify-self: end;
				grid-column: 1 / -1;
			}

			.inference-sampled {
				margin-top: 16px;
				border-left: 2px solid color-mix(in srgb, #84a6d8 60%, #222);
				color: #999;
				font-size: 13px;
				line-height: 1.5;
				padding-left: 14px;
			}

			.inference-sampled strong {
				color: #eae7e0;
			}

			.inference-output {
				margin-top: 22px;
				border: 1px solid rgba(226, 223, 216, 0.14);
				border-radius: 6px;
				background: rgba(10, 10, 10, 0.42);
				padding: 18px 20px;
			}

			.inference-output-text {
				color: #eae7e0;
				font-size: 22px;
				font-weight: 700;
				line-height: 1.35;
			}

			.inference-context-generated.is-appending,
			.inference-output-text.is-appending {
				animation: inference-append-pop 0.42s ease both;
			}

			.inference-moving-token {
				position: absolute;
				top: 45%;
				right: 26%;
				border: 1px solid color-mix(in srgb, var(--llms-accent) 64%, #e2dfd8);
				border-radius: 999px;
				background: color-mix(in srgb, var(--llms-accent) 16%, #101010);
				color: #eae7e0;
				font-size: 13px;
				font-weight: 700;
				line-height: 1;
				opacity: 0;
				padding: 9px 12px;
				pointer-events: none;
				transform: translate(0, 0);
				z-index: 2;
			}

			.inference-visual.is-append-active .inference-moving-token {
				animation: inference-token-move 0.58s ease both;
			}

			:global(.mini-probability-row.is-selected) {
				border-color: color-mix(in srgb, var(--mini-probability-accent) 72%, #e2dfd8);
				box-shadow: 0 0 0 1px color-mix(in srgb, var(--mini-probability-accent) 22%, transparent);
			}

			:global(.mini-probability-row.is-selected::after) {
				content: 'sampled';
				position: relative;
				border: 1px solid color-mix(in srgb, var(--mini-probability-accent) 48%, #252525);
				border-radius: 999px;
				color: color-mix(in srgb, var(--mini-probability-accent) 82%, #eae7e0);
				font-size: 9px;
				font-weight: 700;
				letter-spacing: 1px;
				line-height: 1;
				padding: 6px 7px;
				text-transform: uppercase;
