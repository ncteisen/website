				}

				.example-source-list {
					grid-template-columns: 1fr;
				}

				.training-copy {
					grid-template-columns: 1fr;
					gap: 24px;
				}

				.weights-copy {
					grid-template-columns: 1fr;
					gap: 24px;
				}

				.inference-copy {
					grid-template-columns: 1fr;
					gap: 24px;
				}

				.replay-button {
					justify-self: start;
				}

