							<p class="body-copy body-copy--short">
								The context window goes in. The weights shape the equation. A probability map comes out.
							</p>
						</div>
						<div class="control-row">
							<button class="replay-button" type="button" data-weights-replay>
								Tune knobs
							</button>
							<button class="replay-button" type="button" data-weights-reset>
								Reset
							</button>
						</div>
					</div>

					<div class="weights-visual" data-weights-visual aria-label="Neural net weights diagram">
						<p class="weights-visual-title">Inside the Neural Net</p>
						<div class="equation-flow">
							<div class="equation-node">
								<span class="equation-label">Input</span>
								<p class="equation-main">Context window</p>
								<div class="mini-token-row" aria-label="Example context tokens">
									{throughlineExamples[0].trainingTokens.map((token) => (
										<span class="mini-token">
											<span class="mini-token-id">{token.id}</span>
											<span class="mini-token-label">{token.label.replaceAll('"', '')}</span>
										</span>
									))}
								</div>
							</div>

							<div class="equation-arrow" aria-hidden="true">&rarr;</div>

							<div class="equation-core">
								<span class="equation-label">Neural net</span>
								<span class="equation-symbol">f(x, weights)</span>
								<p class="equation-sub">A gigantic mathematical equation with many learned parameters.</p>
							</div>

							<div class="equation-arrow" aria-hidden="true">&rarr;</div>

							<div class="equation-node">
								<span class="equation-label">Output</span>
								<p class="equation-main">Probability map</p>
								<div aria-label="Example output probabilities">
									<div class="mini-probability-row" style="--mini-probability-width: 80%; --mini-probability-accent: #8f9f86">
										<span>Paris</span>
										<span class="mini-probability-value" data-weight-probability="paris">80%</span>
									</div>
									<div class="mini-probability-row" style="--mini-probability-width: 18%; --mini-probability-accent: #d6a561">
										<span>France</span>
										<span class="mini-probability-value" data-weight-probability="france">18%</span>
									</div>
									<div class="mini-probability-ellipsis" aria-label="Many more token probabilities">...</div>
								</div>
							</div>
						</div>

						<div class="knob-panel">
							<span class="equation-label">Parameters / weights</span>
							<div class="knob-grid" aria-label="Illustration of many neural net weights as knobs">
								{knobAngles.map((angle, index) => (
									<div class="weight-knob" aria-hidden="true">
										<span
											class="weight-needle"
											data-knob-angle={angle}
