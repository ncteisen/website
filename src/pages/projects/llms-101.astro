				justify-items: center;
			}

			.weight-knob {
				aspect-ratio: 1;
				width: 26px;
				border: 1.5px solid rgba(226, 223, 216, 0.64);
				border-bottom-color: transparent;
				border-radius: 999px;
				position: relative;
				background:
					radial-gradient(circle at center, rgba(10, 10, 10, 0.2) 0 38%, transparent 39%),
					rgba(226, 223, 216, 0.03);
			}

			.weight-knob::before {
				content: '';
				position: absolute;
				inset: 4px;
				border-radius: 999px;
				background:
					repeating-conic-gradient(from -120deg, rgba(226, 223, 216, 0.7) 0 3deg, transparent 3deg 18deg);
				mask: radial-gradient(circle, transparent 0 68%, #000 69%);
				opacity: 0.85;
			}

			.weight-needle {
				position: absolute;
				left: 50%;
				top: 50%;
				width: 2px;
				height: 36%;
				border-radius: 999px;
				background: #30a6bf;
				box-shadow: 0 0 12px rgba(48, 166, 191, 0.4);
				transform: translate(-50%, -96%) rotate(var(--knob-start));
				transform-origin: 50% 96%;
			}

			.weights-visual.is-tuning .weight-needle {
				animation: tune-knob 0.8s ease both;
				animation-delay: var(--knob-delay);
			}

			.weights-note {
				margin-top: 18px;
				border-left: 2px solid color-mix(in srgb, #8f9f86 60%, #222);
				color: #999;
				font-size: 13px;
				line-height: 1.6;
				padding-left: 14px;
			}

			.inference-section {
				width: auto;
				margin-left: 0;
				transform: none;
			}

			.inference-layout {
				display: grid;
				grid-template-columns: 1fr;
				gap: 28px;
				align-items: start;
			}

			.inference-copy {
				display: grid;
				grid-template-columns: minmax(0, 1fr) auto;
				gap: 32px;
				align-items: end;
			}

			.inference-copy .promise {
				max-width: 760px;
				margin-bottom: 14px;
			}

			.inference-visual {
				border: 1px solid #1c1c1c;
				border-radius: 6px;
				background:
					linear-gradient(135deg, color-mix(in srgb, #84a6d8 14%, #111), #0f0f0f 55%),
					repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.035) 0 1px, transparent 1px 18px);
				padding: 34px;
				position: relative;
				overflow: hidden;
				box-shadow: 0 24px 70px rgba(0, 0, 0, 0.26);
			}

			.inference-visual-title {
				font-size: 12px;
				color: #6f6f6f;
				letter-spacing: 2px;
				text-transform: uppercase;
				margin-bottom: 24px;
			}

			.inference-flow {
				display: grid;
				grid-template-columns: minmax(300px, 1fr) minmax(120px, 0.3fr) minmax(320px, 1fr);
				gap: 28px;
				align-items: center;
			}

			.inference-panel {
				border: 1px solid rgba(226, 223, 216, 0.14);
				border-radius: 6px;
				background: rgba(10, 10, 10, 0.42);
				min-height: 250px;
				padding: 20px;
				transition:
					border-color 0.18s ease,
					box-shadow 0.18s ease,
					background 0.18s ease,
					opacity 0.18s ease;
			}

			.inference-map-panel {
				border-color: rgba(132, 166, 216, 0.24);
				background:
					linear-gradient(135deg, rgba(132, 166, 216, 0.08), rgba(10, 10, 10, 0.42) 52%),
					rgba(10, 10, 10, 0.42);
			}

			.inference-context-text {
				color: #eae7e0;
				font-size: 24px;
				font-weight: 700;
				line-height: 1.35;
			}

			.inference-context-base {
				color: #aaa49a;
			}

			.inference-context-generated {
				color: var(--llms-accent);
			}

			.inference-net {
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 10px;
				color: #777;
				font-size: 12px;
				font-weight: 700;
				letter-spacing: 1.4px;
				text-align: center;
				text-transform: uppercase;
				transition:
					color 0.18s ease,
					transform 0.18s ease;
			}

			.inference-visual.is-context-active [data-inference-context-panel],
			.inference-visual.is-map-active [data-inference-map-panel],
			.inference-visual.is-choice-active [data-inference-map-panel],
			.inference-visual.is-append-active [data-inference-context-panel],
			.inference-visual.is-append-active .inference-output {
				border-color: color-mix(in srgb, var(--llms-accent) 62%, #e2dfd8);
