							rel="noopener noreferrer"
							data-umami-event="link_click"
							data-umami-event-area="llms-101"
							data-umami-event-label="attention-is-all-you-need-paper"
						>
							<span class="paper-date">June 12, 2017</span>
							Attention Is All You Need
						</a>
					</div>

					<ul class="checkpoint-list">
						<li>A token-level internet document simulator.</li>
						<li>Probabilistic. Run it again and you may sample a different continuation.</li>
