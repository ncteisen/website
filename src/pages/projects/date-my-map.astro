---
import UmamiAnalytics from '../../components/UmamiAnalytics.astro';
import IconLinks from '../../components/IconLinks.astro';
import SocialPreview from '../../components/SocialPreview.astro';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<IconLinks />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Date My Map | Noah Eisen</title>
		<SocialPreview
			title="Noah Eisen - Date My Map"
			description="A project page in progress."
			path="/projects/date-my-map/"
		/>
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />
		<UmamiAnalytics />
		<style>
			*, *::before, *::after {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				min-height: 100vh;
				background: #0a0a0a;
				color: #ece9e2;
				font-family: 'DM Sans', sans-serif;
			}

			main {
				display: grid;
				min-height: 100vh;
				place-items: center;
				padding: 48px 24px;
			}

			.content {
				width: min(100%, 680px);
			}

			a {
				color: #8eb1ff;
				text-decoration: none;
			}

			a:hover {
				text-decoration: underline;
			}

			h1 {
				margin: 0;
				font-size: clamp(44px, 9vw, 84px);
				font-weight: 600;
				line-height: 0.95;
			}

			p {
				margin: 18px 0 0;
				color: #b8b3a9;
				font-size: 18px;
				line-height: 1.55;
			}

			.back-link {
				display: inline-flex;
				margin-top: 32px;
				font-size: 14px;
			}
		</style>
	</head>
	<body>
		<main>
			<div class="content">
				<h1>Date My Map</h1>
				<p>This project is being restarted from scratch.</p>
				<a href="/projects" class="back-link" data-umami-event="link_click" data-umami-event-area="navigation" data-umami-event-label="projects">&larr; Back to Projects</a>
			</div>
		</main>
	</body>
</html>
