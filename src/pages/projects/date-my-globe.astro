---
import SocialPreview from '../../components/SocialPreview.astro';
import UmamiAnalytics from '../../components/UmamiAnalytics.astro';
import { dateMyGlobeEvents } from '../../data/dateMyGlobeEvents';

const supportedStartYear = 1500;
const currentYear = new Date().getFullYear();
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Date My Globe | Noah Eisen</title>
		<SocialPreview
			title="Noah Eisen - Date My Globe"
			description="Estimate when a globe was made from visible political borders and place names."
			path="/projects/date-my-globe/"
		/>
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300;1,9..40,400&display=swap" rel="stylesheet" />
		<UmamiAnalytics />
		<style>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			html { min-height: 100%; scroll-behavior: smooth; }

			body {
				min-height: 100%;
				background: #0a0a0a;
				color: #e2dfd8;
				font-family: 'DM Sans', sans-serif;
				-webkit-font-smoothing: antialiased;
			}

			body[data-min-year] {
				--globe-accent: #83b8a1;
				--globe-accent-soft: color-mix(in srgb, var(--globe-accent) 18%, transparent);
				--globe-border: #1d1d1d;
				--globe-muted: #878179;
				--globe-dim: #555;
			}

			[hidden] { display: none !important; }

			a {
				color: var(--globe-accent);
				text-decoration: none;
			}

			a:hover { text-decoration: underline; }

			button {
				font: inherit;
			}

			.wrap {
				width: min(100%, 900px);
				margin: 0 auto;
				padding: 64px 44px 88px;
			}

			.back-link {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				margin-bottom: 34px;
				color: #666;
				font-size: 11px;
				letter-spacing: 1px;
				text-transform: uppercase;
				transition: color 0.15s;
			}

			.back-link:hover {
				color: #999;
				text-decoration: none;
			}

			.hero {
				max-width: 720px;
				padding-bottom: 42px;
				border-bottom: 1px solid var(--globe-border);
			}

			.project-kicker,
			.section-label,
			.progress-label,
			.event-region {
				color: #4d4d4d;
				font-size: 10px;
				letter-spacing: 4px;
				text-transform: uppercase;
			}

			.project-title {
				margin-top: 18px;
				color: #eae7e0;
				font-size: 72px;
				font-weight: 700;
				letter-spacing: 0;
				line-height: 0.95;
			}

			.project-description {
				max-width: 620px;
				margin-top: 22px;
				color: #9a948b;
				font-size: 15px;
				line-height: 1.75;
			}

			.range-note {
				margin-top: 18px;
				color: #6f6960;
				font-size: 13px;
				line-height: 1.7;
			}

			.action-row {
				display: flex;
				flex-wrap: wrap;
				gap: 12px;
				margin-top: 28px;
			}

			.action-button,
			.answer-button {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-height: 42px;
				border: 1px solid color-mix(in srgb, var(--globe-accent) 46%, #222);
				border-radius: 6px;
				background: var(--globe-accent-soft);
				color: #e8e5dd;
				cursor: pointer;
				font-size: 13px;
				font-weight: 600;
				letter-spacing: 0.2px;
				transition: border-color 0.15s, background 0.15s, transform 0.15s;
			}

			.action-button {
				padding: 0 18px;
			}

			.inline-link {
				display: inline-flex;
				margin-top: 22px;
				color: color-mix(in srgb, var(--globe-accent) 78%, #e2dfd8);
				font-size: 13px;
				font-weight: 600;
			}

			.action-button:hover,
			.answer-button:hover,
			.action-button:focus-visible,
			.answer-button:focus-visible {
				border-color: color-mix(in srgb, var(--globe-accent) 72%, #444);
				background: color-mix(in srgb, var(--globe-accent) 25%, transparent);
				text-decoration: none;
				transform: translateY(-1px);
			}

			.action-button.secondary {
				background: transparent;
				border-color: #2a2a2a;
				color: #9a948b;
			}

			.action-button.copied {
				border-color: color-mix(in srgb, var(--globe-accent) 68%, #222);
				background: color-mix(in srgb, var(--globe-accent) 20%, transparent);
				color: #e8e5dd;
			}

			.range-chip {
				display: inline-flex;
				margin-top: 22px;
				border: 1px solid color-mix(in srgb, var(--globe-accent) 42%, #222);
				border-radius: 999px;
				padding: 8px 12px;
				color: color-mix(in srgb, var(--globe-accent) 76%, #e2dfd8);
				font-size: 12px;
				font-weight: 600;
			}

			.section {
				padding-top: 36px;
			}

			.section-header {
				display: flex;
				align-items: end;
				justify-content: space-between;
				gap: 24px;
				margin-bottom: 22px;
			}

			.section-copy {
				max-width: 520px;
				color: #777;
				font-size: 13px;
				line-height: 1.7;
			}

			.question-shell {
				border-top: 0;
			}

			.question-card {
				padding: 0 0 24px;
				border-bottom: 1px solid var(--globe-border);
			}

			.result-panel {
				padding: 30px 0;
				border-bottom: 1px solid var(--globe-border);
			}

			.result-main {
				max-width: 620px;
			}

			.question-title,
			.result-title {
				color: #eae7e0;
				font-size: 30px;
				font-weight: 700;
				letter-spacing: 0;
				line-height: 1.15;
			}

			.question-description,
			.result-copy,
			.bound-copy,
			:global(.bound-copy) {
				margin-top: 14px;
				color: #8d877f;
				font-size: 14px;
				line-height: 1.75;
			}

			.source-link,
			:global(.source-link) {
				display: inline-flex;
				margin-top: 12px;
				color: color-mix(in srgb, var(--globe-accent) 72%, #666);
				font-size: 11px;
				font-weight: 500;
				text-decoration: none;
			}

			.source-link:hover,
			:global(.source-link:hover) {
				color: var(--globe-accent);
				text-decoration: underline;
			}

			:global(.bound-title) {
				color: #e2dfd8;
				font-size: 15px;
				font-weight: 700;
				line-height: 1.35;
			}

			.share-panel {
				display: flex;
				flex-wrap: wrap;
				gap: 10px 16px;
				align-items: center;
				margin-top: 14px;
			}

			.share-row {
				display: flex;
				flex-wrap: wrap;
				gap: 12px;
			}

			.result-utility-link {
				display: inline-flex;
				color: color-mix(in srgb, var(--globe-accent) 72%, #666);
				font-size: 12px;
				font-weight: 600;
			}

			.share-panel .action-button {
				min-height: 34px;
				padding: 0 12px;
				font-size: 12px;
			}

			.answer-history {
				padding: 30px 0;
				border-bottom: 1px solid var(--globe-border);
			}

			:global(.answer-history-list) {
				display: grid;
				gap: 14px;
				margin-top: 14px;
			}

			:global(.answer-history-item) {
				border: 1px solid #242424;
				border-radius: 6px;
				background: #0f0f0f;
				padding: 14px;
			}

			:global(.answer-history-meta) {
				display: flex;
				flex-wrap: wrap;
				gap: 8px;
				align-items: center;
				color: #666;
				font-size: 11px;
				letter-spacing: 1px;
				text-transform: uppercase;
			}

			:global(.answer-pill) {
				border: 1px solid color-mix(in srgb, var(--globe-accent) 42%, #222);
				border-radius: 999px;
				color: var(--globe-accent);
				padding: 3px 8px;
			}

			:global(.answer-history-question) {
				margin-top: 9px;
				color: #d9d4cb;
				font-size: 13px;
				font-weight: 600;
				line-height: 1.45;
			}

			:global(.answer-history-event) {
				margin-top: 7px;
				color: #777;
				font-size: 12px;
				line-height: 1.5;
			}

			:global(.answer-range) {
				margin-top: 14px;
			}

			:global(.answer-range-labels) {
				display: flex;
				justify-content: space-between;
				color: #5f5a53;
				font-size: 10px;
				letter-spacing: 1px;
				text-transform: uppercase;
			}

			:global(.answer-range-track) {
				position: relative;
				height: 6px;
				margin-top: 8px;
				border-radius: 999px;
				background: #242424;
				overflow: hidden;
			}

			:global(.answer-range-window) {
				position: absolute;
				top: 0;
				bottom: 0;
				border-radius: inherit;
				background: var(--globe-accent);
				box-shadow: 0 0 18px color-mix(in srgb, var(--globe-accent) 28%, transparent);
			}

			:global(.answer-range-current) {
				margin-top: 8px;
				color: #8d877f;
				font-size: 12px;
				line-height: 1.5;
			}

			.visual-panel {
				margin-top: 24px;
			}

			.visual-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 12px;
				min-width: 0;
			}

			.map-choice {
				display: flex;
				width: 100%;
				min-width: 0;
				min-height: 330px;
				flex-direction: column;
				justify-content: space-between;
				border: 1px solid #252525;
				border-radius: 6px;
				background:
					radial-gradient(circle at 28% 22%, color-mix(in srgb, var(--globe-accent) 14%, transparent), transparent 38%),
					#0c0c0c;
				color: inherit;
				cursor: pointer;
				padding: 16px;
				text-align: left;
				transition: border-color 0.15s, background 0.15s, transform 0.15s;
			}

			.map-choice:hover,
			.map-choice:focus-visible {
				border-color: color-mix(in srgb, var(--globe-accent) 62%, #333);
				background:
					radial-gradient(circle at 28% 22%, color-mix(in srgb, var(--globe-accent) 20%, transparent), transparent 38%),
					#101312;
				transform: translateY(-1px);
			}

			.map-choice-title {
				color: #e2dfd8;
				font-size: 14px;
				font-weight: 700;
				line-height: 1.25;
			}

			.map-choice-label {
				display: block;
				margin-bottom: 4px;
				color: #666;
				font-size: 10px;
				letter-spacing: 2px;
				text-transform: uppercase;
			}

			.map-svg {
				position: relative;
				width: 100%;
				min-width: 0;
				aspect-ratio: 4 / 3;
				margin: 16px 0;
				border: 1px solid #242424;
				border-radius: 6px;
				background:
					linear-gradient(90deg, transparent 49%, rgba(226, 223, 216, 0.05) 49% 51%, transparent 51%),
					linear-gradient(0deg, transparent 49%, rgba(226, 223, 216, 0.05) 49% 51%, transparent 51%),
					color-mix(in srgb, var(--globe-accent) 10%, #0f0f0f);
				overflow: hidden;
			}

			.map-note {
				color: #777;
				font-size: 12px;
				line-height: 1.55;
			}

			.map-svg :global(svg) {
				position: absolute;
				inset: 0;
				display: block;
				width: 100%;
				height: 100%;
			}

			:global(.geo-feature) {
				stroke: rgba(226, 223, 216, 0.42);
				stroke-width: 0.7;
				vector-effect: non-scaling-stroke;
			}

			:global(.geo-feature--context) {
				fill: rgba(226, 223, 216, 0.12);
			}

			:global(.geo-feature--removed) {
				fill: rgba(214, 165, 97, 0.34);
				stroke: rgba(214, 165, 97, 0.8);
			}

			:global(.geo-feature--added),
			:global(.geo-feature--changed) {
				fill: color-mix(in srgb, var(--globe-accent) 42%, transparent);
				stroke: color-mix(in srgb, var(--globe-accent) 88%, #e2dfd8);
			}

			:global(.geo-label) {
				fill: #e2dfd8;
				font-family: 'DM Sans', sans-serif;
				font-size: 4px;
				font-weight: 700;
				letter-spacing: 0;
				text-anchor: middle;
			}

			.unsure-row {
				margin-top: 14px;
				text-align: center;
			}

			.unsure-link {
				border: 0;
				background: transparent;
				color: #777;
				cursor: pointer;
				font-size: 12px;
				font-weight: 500;
				padding: 4px 8px;
			}

			.unsure-link:hover,
			.unsure-link:focus-visible {
				color: var(--globe-accent);
				text-decoration: underline;
			}

			.result-range {
				margin-top: 12px;
				color: var(--globe-accent);
				font-size: 42px;
				font-weight: 700;
				line-height: 1;
			}

			.bound-list {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 18px;
				margin-top: 28px;
				border-top: 1px solid var(--globe-border);
				padding-top: 22px;
			}

			.bound-title {
				color: #e2dfd8;
				font-size: 15px;
				font-weight: 700;
				line-height: 1.35;
			}

			.timeline,
			.answer-history-list {
				border-top: 1px solid var(--globe-border);
			}

			.timeline-event {
				display: grid;
				grid-template-columns: 110px minmax(0, 1fr);
				gap: 26px;
				padding: 24px 0;
				border-bottom: 1px solid var(--globe-border);
			}

			.timeline-year {
				color: var(--globe-accent);
				font-size: 28px;
				font-weight: 700;
				line-height: 1;
			}

			.timeline-title {
				color: #eae7e0;
				font-size: 19px;
				font-weight: 700;
				line-height: 1.25;
			}

			.timeline-copy {
				margin-top: 8px;
				color: #807970;
				font-size: 13px;
				line-height: 1.7;
			}

			.event-region {
				display: inline-flex;
				margin-bottom: 8px;
				letter-spacing: 2px;
			}

			@media (max-width: 820px) {
				.wrap {
					padding: 44px 24px 68px;
				}

				.question-card,
				.result-panel {
					grid-template-columns: 1fr;
				}

				.project-title {
					font-size: 52px;
				}

			}

			@media (max-width: 560px) {
				.project-title {
					font-size: 42px;
				}

				.section-header {
					display: block;
				}

				.section-copy {
					margin-top: 12px;
				}

				.answer-row,
				.visual-grid {
					grid-template-columns: minmax(0, 1fr);
				}

				.map-choice {
					min-height: 0;
					padding: 12px;
				}

				.map-svg {
					aspect-ratio: 16 / 11;
					margin: 12px 0;
				}

				.timeline-event {
					grid-template-columns: 1fr;
					gap: 10px;
				}

				.result-range {
					font-size: 34px;
				}

				.bound-list {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body data-min-year={supportedStartYear} data-current-year={currentYear}>
		<main class="wrap" role="main">
			<a href="/" class="back-link" data-umami-event="link_click" data-umami-event-area="navigation" data-umami-event-label="home">&larr; Back to Noah Eisen</a>

			<header class="hero">
				<div>
					<h1 class="project-title">Date My Globe</h1>
					<p class="project-description">
						Answer a short sequence of questions about borders and place names on your globe. The tool narrows the possible date by comparing what you see against a curated timeline of geopolitical changes.
					</p>
					<p class="range-note">
						This map-backed checklist currently focuses on twentieth-century and modern clues. The full reference timeline still starts from the
						<a href="https://en.wikipedia.org/wiki/Behaim_Globe" target="_blank" rel="noopener noreferrer">Behaim Globe</a>,
						created around 1492. The result estimates the globe's map-data date, not necessarily its manufacturing date.
					</p>
					<a class="inline-link" href="/map-my-globe/all-events">View all events &rarr;</a>
				</div>
			</header>

			<section class="section" id="checklist" aria-labelledby="checklist-title">
				<div class="question-shell" id="question-shell" aria-live="polite">
					<div class="question-card" id="question-card">
						<div>
							<h3 class="question-title" id="question-title"></h3>
							<p class="question-description" id="question-description"></p>
							<a class="source-link" id="question-source" target="_blank" rel="noopener noreferrer">Source &rarr;</a>
						</div>

						<div class="visual-panel" aria-label="Before and after map choices">
							<div class="visual-grid">
								<button class="map-choice" type="button" data-answer="no" id="before-map-button">
									<div>
										<span class="map-choice-label">Before</span>
										<p class="map-choice-title" id="before-label"></p>
										<div class="map-svg" id="before-map" aria-hidden="true"></div>
									</div>
									<p class="map-note" id="before-note"></p>
								</button>
								<button class="map-choice" type="button" data-answer="yes" id="after-map-button">
									<div>
										<span class="map-choice-label">After</span>
										<p class="map-choice-title" id="after-label"></p>
										<div class="map-svg" id="after-map" aria-hidden="true"></div>
									</div>
									<p class="map-note" id="after-note"></p>
								</button>
							</div>
						</div>

						<div class="unsure-row">
							<button class="unsure-link" type="button" data-answer="unsure">Unsure</button>
						</div>
					</div>

					<div class="result-panel" id="result-panel" hidden>
						<div class="result-main">
							<h3 class="result-title">Your globe is likely from:</h3>
							<p class="result-range" id="result-range"></p>
							<p class="result-copy" id="result-copy"></p>
							<div class="share-panel">
								<div class="share-row">
									<button class="action-button secondary" type="button" id="copy-share-button">Copy link</button>
								</div>
								<a class="result-utility-link" href="/map-my-globe/all-events">View all events &rarr;</a>
							</div>
						</div>

						<div class="bound-list" aria-label="Bounding events">
							<div id="lower-bound"></div>
							<div id="upper-bound"></div>
						</div>
					</div>

					<div class="answer-history" id="answered-timeline" hidden>
						<div class="section-header">
							<div>
								<span class="section-label">Answered timeline</span>
								<h2 class="question-title">The clues you checked</h2>
							</div>
							<p class="section-copy">
								These are the events used for this result. The full event catalog lives on a separate reference page.
							</p>
						</div>
						<div class="answer-history-list" id="answer-history-list"></div>
						<a class="inline-link" href="/map-my-globe/all-events">View all events &rarr;</a>
					</div>
				</div>
			</section>
		</main>

		<script type="application/json" id="date-my-globe-events" set:html={JSON.stringify(dateMyGlobeEvents)}></script>
		<script>
			const eventsElement = document.getElementById('date-my-globe-events');
			const allEvents = JSON.parse(eventsElement?.textContent || '[]').sort((a, b) => a.year - b.year);
			const events = allEvents.filter((event) => event.includeInChecklist && event.beforeMap && event.afterMap);
			const minSupportedYear = Number(document.body.dataset.minYear || '1500');
			const currentYear = Number(document.body.dataset.currentYear || String(new Date().getFullYear()));
			const mappedTimelineStartYear = events[0]?.year ?? minSupportedYear;
			const mappedTimelineEndYear = events[events.length - 1]?.year ?? currentYear;

			const questionCard = document.getElementById('question-card');
			const resultPanel = document.getElementById('result-panel');
			const questionTitle = document.getElementById('question-title');
			const questionDescription = document.getElementById('question-description');
			const questionSource = document.getElementById('question-source');
			const beforeLabel = document.getElementById('before-label');
			const afterLabel = document.getElementById('after-label');
			const beforeNote = document.getElementById('before-note');
			const afterNote = document.getElementById('after-note');
			const beforeMap = document.getElementById('before-map');
			const afterMap = document.getElementById('after-map');
			const beforeMapButton = document.getElementById('before-map-button');
			const afterMapButton = document.getElementById('after-map-button');
			const resultRange = document.getElementById('result-range');
			const resultCopy = document.getElementById('result-copy');
			const lowerBound = document.getElementById('lower-bound');
			const upperBound = document.getElementById('upper-bound');
			const copyShareButton = document.getElementById('copy-share-button');
			const answerHistoryList = document.getElementById('answer-history-list');
			const answeredTimeline = document.getElementById('answered-timeline');
			let copyResetTimer;

			const answerCodes = {
				yes: 'y',
				no: 'n',
				unsure: 'u',
			};
			const answersByCode = {
				y: 'yes',
				n: 'no',
				u: 'unsure',
			};
			const answerLabels = {
				yes: 'After',
				no: 'Before',
				unsure: 'Unsure',
			};

			let earliestYear = minSupportedYear;
			let latestYear = currentYear;
			let currentEvent = null;
			let lowerBoundEvent = null;
			let upperBoundEvent = null;
			let askedEventIds = new Set();
			let skippedEvents = [];
			let answerHistory = [];

			function formatRange() {
				return `${earliestYear}-${latestYear >= currentYear ? 'present' : latestYear}`;
			}

			function formatRangeSnapshot(range) {
				return `${range.earliestYear}-${range.latestYear >= currentYear ? 'present' : range.latestYear}`;
			}

			function getRangePercent(year) {
				const span = mappedTimelineEndYear - mappedTimelineStartYear;
				if (span <= 0) {
					return 0;
				}

				return Math.min(100, Math.max(0, ((year - mappedTimelineStartYear) / span) * 100));
			}

			function getCandidates() {
				return events.filter((event) => (
					!askedEventIds.has(event.id) &&
					event.year > earliestYear &&
					event.year <= latestYear
				));
			}

			function getNextEvent() {
				const candidates = getCandidates();
				if (!candidates.length) {
					return null;
				}

				return candidates[Math.floor((candidates.length - 1) / 2)];
			}

			function projectPoint(point, viewport) {
				const [lon, lat] = point;
				const x = ((lon - viewport.west) / (viewport.east - viewport.west)) * 100;
				const y = ((viewport.north - lat) / (viewport.north - viewport.south)) * 100;
				return [x, y];
			}

			function polygonPath(feature, viewport) {
				return feature.geometry.coordinates.map((ring) => ring.map((point, index) => {
					const [x, y] = projectPoint(point, viewport);
					return `${index === 0 ? 'M' : 'L'}${x.toFixed(2)} ${y.toFixed(2)}`;
				}).join(' ') + ' Z').join(' ');
			}

			function polygonCenter(feature, viewport) {
				const ring = feature.geometry.coordinates[0];
				const projected = ring.slice(0, -1).map((point) => projectPoint(point, viewport));
				const total = projected.reduce((sum, point) => [sum[0] + point[0], sum[1] + point[1]], [0, 0]);
				return [total[0] / projected.length, total[1] / projected.length];
			}

			function renderMap(target, event, map) {
				if (!target || !event.mapViewport || !map) {
					return;
				}

				const featureStyles = {
					context: {
						fill: 'rgba(226, 223, 216, 0.12)',
						stroke: 'rgba(226, 223, 216, 0.42)',
					},
					removed: {
						fill: 'rgba(214, 165, 97, 0.34)',
						stroke: 'rgba(214, 165, 97, 0.8)',
					},
					added: {
						fill: 'rgba(131, 184, 161, 0.42)',
						stroke: 'rgba(184, 220, 202, 0.95)',
					},
				};
				const svgNamespace = 'http://www.w3.org/2000/svg';
				const svg = document.createElementNS(svgNamespace, 'svg');
				svg.setAttribute('viewBox', '-4 -4 108 108');
				svg.setAttribute('preserveAspectRatio', 'xMidYMid meet');
				svg.setAttribute('role', 'img');
				svg.setAttribute('aria-label', map.label);

				const background = document.createElementNS(svgNamespace, 'rect');
				background.setAttribute('x', '0');
				background.setAttribute('y', '0');
				background.setAttribute('width', '100');
				background.setAttribute('height', '100');
				background.setAttribute('fill', 'transparent');
				svg.append(background);

				map.features.forEach((feature) => {
					const style = featureStyles[feature.properties.role] ?? featureStyles.context;
					const path = document.createElementNS(svgNamespace, 'path');
					path.setAttribute('d', polygonPath(feature, event.mapViewport));
					path.setAttribute('class', `geo-feature geo-feature--${feature.properties.role}`);
					path.setAttribute('fill', style.fill);
					path.setAttribute('stroke', style.stroke);
					path.setAttribute('stroke-width', '0.7');
					path.setAttribute('vector-effect', 'non-scaling-stroke');
					svg.append(path);
				});

				map.features.forEach((feature) => {
					if (feature.properties.role === 'context') {
						return;
					}

					const [x, y] = polygonCenter(feature, event.mapViewport);
					const label = document.createElementNS(svgNamespace, 'text');
					label.setAttribute('x', x.toFixed(2));
					label.setAttribute('y', y.toFixed(2));
					label.setAttribute('class', 'geo-label');
					label.setAttribute('fill', '#e2dfd8');
					label.setAttribute('font-size', '4');
					label.setAttribute('font-family', 'DM Sans, sans-serif');
					label.setAttribute('font-weight', '700');
					label.setAttribute('text-anchor', 'middle');
					label.textContent = feature.properties.label;
					svg.append(label);
				});

				target.replaceChildren(svg);
			}

			function renderQuestion() {
				currentEvent = getNextEvent();

				if (!currentEvent) {
					renderResult();
					return;
				}

				if (questionTitle) {
					questionTitle.textContent = currentEvent.question;
				}
				if (questionDescription) {
					questionDescription.textContent = currentEvent.description;
				}
				if (questionSource) {
					questionSource.innerHTML = `${currentEvent.sourceLabel} &rarr;`;
					questionSource.setAttribute('href', currentEvent.sourceUrl);
				}
				if (beforeLabel) {
					beforeLabel.textContent = currentEvent.beforeLabel;
				}
				if (afterLabel) {
					afterLabel.textContent = currentEvent.afterLabel;
				}
				if (beforeNote) {
					beforeNote.textContent = currentEvent.beforeMap?.note ?? currentEvent.visualPlaceholder.beforeNote;
				}
				if (afterNote) {
					afterNote.textContent = currentEvent.afterMap?.note ?? currentEvent.visualPlaceholder.afterNote;
				}
				if (beforeMapButton) {
					beforeMapButton.setAttribute('aria-label', `Before: ${currentEvent.beforeLabel}`);
				}
				if (afterMapButton) {
					afterMapButton.setAttribute('aria-label', `After: ${currentEvent.afterLabel}`);
				}
				renderMap(beforeMap, currentEvent, currentEvent.beforeMap);
				renderMap(afterMap, currentEvent, currentEvent.afterMap);
			}

			function renderBound(target, heading, event, fallbackCopy) {
				if (!target) {
					return;
				}

				if (!event) {
					target.innerHTML = `
						<h4 class="bound-title">${heading}</h4>
						<p class="bound-copy">${fallbackCopy}</p>
					`;
					return;
				}

				target.innerHTML = `
					<h4 class="bound-title">${heading}: ${event.name} (${event.year})</h4>
					<p class="bound-copy">${event.description}</p>
					<a class="source-link" href="${event.sourceUrl}" target="_blank" rel="noopener noreferrer">${event.sourceLabel} &rarr;</a>
				`;
			}

			function getShareState() {
				return answerHistory
					.map((entry) => `${entry.event.id}:${answerCodes[entry.answer]}`)
					.join(',');
			}

			function getShareUrl() {
				const url = new URL(window.location.href);
				url.searchParams.set('globe', getShareState());
				url.hash = 'checklist';
				return url.toString();
			}

			function renderAnswerHistory() {
				if (!answerHistoryList) {
					return;
				}

				answerHistoryList.replaceChildren();

				answerHistory.forEach((entry, index) => {
					const item = document.createElement('article');
					item.className = 'answer-history-item';

					const meta = document.createElement('div');
					meta.className = 'answer-history-meta';
					meta.textContent = `Question ${index + 1}`;

					const answer = document.createElement('span');
					answer.className = 'answer-pill';
					answer.textContent = answerLabels[entry.answer];
					meta.append(answer);

					const question = document.createElement('p');
					question.className = 'answer-history-question';
					question.textContent = entry.event.question;

					const event = document.createElement('p');
					event.className = 'answer-history-event';
					event.textContent = `${entry.event.name} (${entry.event.year})`;

					const range = document.createElement('div');
					range.className = 'answer-range';

					const labels = document.createElement('div');
					labels.className = 'answer-range-labels';

					const startLabel = document.createElement('span');
					startLabel.textContent = String(mappedTimelineStartYear);
					const endLabel = document.createElement('span');
					endLabel.textContent = String(mappedTimelineEndYear);
					labels.append(startLabel, endLabel);

					const track = document.createElement('div');
					track.className = 'answer-range-track';

					const window = document.createElement('div');
					window.className = 'answer-range-window';
					const left = getRangePercent(entry.rangeAfter.earliestYear);
					const right = getRangePercent(entry.rangeAfter.latestYear);
					window.style.left = `${left}%`;
					window.style.width = `${Math.max(1.5, right - left)}%`;
					track.append(window);

					const current = document.createElement('p');
					current.className = 'answer-range-current';
					current.textContent = `Possible after this answer: ${formatRangeSnapshot(entry.rangeAfter)}`;

					range.append(labels, track, current);

					item.append(meta, question, event, range);
					answerHistoryList.append(item);
				});
			}

			function renderResult() {
				if (questionCard) {
					questionCard.hidden = true;
				}
				if (resultPanel) {
					resultPanel.hidden = false;
				}

				if (resultRange) {
					resultRange.textContent = formatRange();
				}
				if (resultCopy) {
					resultCopy.textContent = `This range comes from the clearest confirmed before-and-after clues. It dates the political geography represented on the globe, which can be earlier than the date the object was manufactured.`;
				}
				renderBound(
					lowerBound,
					'Earliest bound',
					lowerBoundEvent,
					`No confirmed lower bound beyond the supported start year of ${minSupportedYear}.`
				);
				renderBound(
					upperBound,
					'Latest bound',
					upperBoundEvent,
					'No confirmed upper bound beyond the current event list.'
				);
				renderAnswerHistory();
				if (copyShareButton) {
					copyShareButton.textContent = 'Copy link';
					copyShareButton.classList.remove('copied');
				}
				if (answeredTimeline) {
					answeredTimeline.hidden = false;
				}
			}

			function applyAnswer(event, answer) {
				if (!event || !answerCodes[answer] || askedEventIds.has(event.id)) {
					return;
				}

				askedEventIds.add(event.id);

				if (answer === 'yes') {
					earliestYear = Math.max(earliestYear, event.year);
					lowerBoundEvent = event;
				} else if (answer === 'no') {
					latestYear = Math.min(latestYear, event.year - 1);
					upperBoundEvent = event;
				} else {
					skippedEvents.push(event);
				}

				if (latestYear < earliestYear) {
					latestYear = earliestYear;
				}

				answerHistory.push({
					event,
					answer,
					rangeAfter: {
						earliestYear,
						latestYear,
					},
				});
			}

			function answerQuestion(answer) {
				if (!currentEvent) {
					return;
				}

				applyAnswer(currentEvent, answer);
				renderQuestion();
			}

			function resetChecklistState() {
				earliestYear = minSupportedYear;
				latestYear = currentYear;
				currentEvent = null;
				lowerBoundEvent = null;
				upperBoundEvent = null;
				askedEventIds = new Set();
				skippedEvents = [];
				answerHistory = [];
			}

			function clearSharedUrl() {
				const url = new URL(window.location.href);
				if (!url.searchParams.has('globe')) {
					return;
				}

				url.searchParams.delete('globe');
				history.replaceState(null, '', `${url.pathname}${url.search}${url.hash}`);
			}

			function restartChecklist() {
				resetChecklistState();
				clearSharedUrl();

				if (questionCard) {
					questionCard.hidden = false;
				}
				if (resultPanel) {
					resultPanel.hidden = true;
				}
				if (answeredTimeline) {
					answeredTimeline.hidden = true;
				}

				renderQuestion();
			}

			function loadSharedChecklist() {
				const sharedState = new URLSearchParams(window.location.search).get('globe');
				if (!sharedState) {
					restartChecklist();
					return;
				}

				resetChecklistState();

				const sharedAnswers = sharedState.split(',').map((entry) => {
					const [eventId, code] = entry.split(':');
					return {
						eventId,
						answer: answersByCode[code],
					};
				});

				for (const sharedAnswer of sharedAnswers) {
					const expectedEvent = getNextEvent();
					if (!expectedEvent || expectedEvent.id !== sharedAnswer.eventId || !sharedAnswer.answer) {
						break;
					}

					applyAnswer(expectedEvent, sharedAnswer.answer);
				}

				if (questionCard) {
					questionCard.hidden = false;
				}
				if (resultPanel) {
					resultPanel.hidden = true;
				}
				if (answeredTimeline) {
					answeredTimeline.hidden = true;
				}
				renderQuestion();
			}

			function copyTextWithSelection(text) {
				const textarea = document.createElement('textarea');
				const activeElement = document.activeElement;
				textarea.value = text;
				textarea.setAttribute('readonly', '');
				textarea.setAttribute('aria-hidden', 'true');
				textarea.style.position = 'fixed';
				textarea.style.top = '0';
				textarea.style.left = '0';
				textarea.style.width = '1px';
				textarea.style.height = '1px';
				textarea.style.opacity = '0';
				textarea.style.pointerEvents = 'none';
				document.body.append(textarea);
				textarea.focus({ preventScroll: true });
				textarea.select();
				textarea.setSelectionRange(0, textarea.value.length);

				let copied = false;
				try {
					copied = document.execCommand('copy');
				} finally {
					textarea.remove();
					if (activeElement instanceof HTMLElement) {
						activeElement.focus({ preventScroll: true });
					}
				}

				return copied;
			}

			async function copyText(text) {
				if (copyTextWithSelection(text)) {
					return true;
				}

				if (window.navigator?.clipboard?.writeText) {
					try {
						await window.navigator.clipboard.writeText(text);
						return true;
					} catch {
						return false;
					}
				}

				return false;
			}

			document.querySelectorAll('[data-answer]').forEach((button) => {
				button.addEventListener('click', () => {
					answerQuestion(button.getAttribute('data-answer'));
				});
			});

			copyShareButton?.addEventListener('click', async () => {
				const shareUrl = getShareUrl();

				if (await copyText(shareUrl)) {
					window.clearTimeout(copyResetTimer);
					copyShareButton.textContent = 'Copied';
					copyShareButton.classList.add('copied');
					copyResetTimer = window.setTimeout(() => {
						copyShareButton.textContent = 'Copy link';
						copyShareButton.classList.remove('copied');
					}, 1400);
					return;
				}

				copyShareButton.textContent = 'Copy failed';
				copyResetTimer = window.setTimeout(() => {
					copyShareButton.textContent = 'Copy link';
				}, 1800);
			});

			loadSharedChecklist();
		</script>
	</body>
</html>
