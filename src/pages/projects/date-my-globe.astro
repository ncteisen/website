---
import SocialPreview from '../../components/SocialPreview.astro';
import UmamiAnalytics from '../../components/UmamiAnalytics.astro';
import { dateMyGlobeEvents } from '../../data/dateMyGlobeEvents';

const supportedStartYear = 1500;
const currentYear = new Date().getFullYear();
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Date My Globe | Noah Eisen</title>
		<SocialPreview
			title="Noah Eisen - Date My Globe"
			description="Estimate when a globe was made from visible political borders and place names."
			path="/projects/date-my-globe/"
		/>
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300;1,9..40,400&display=swap" rel="stylesheet" />
		<UmamiAnalytics />
		<style>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			html { min-height: 100%; scroll-behavior: smooth; }

			body {
				min-height: 100%;
				background: #0a0a0a;
				color: #e2dfd8;
				font-family: 'DM Sans', sans-serif;
				-webkit-font-smoothing: antialiased;
			}

			body[data-min-year] {
				--globe-accent: #83b8a1;
				--globe-accent-soft: color-mix(in srgb, var(--globe-accent) 18%, transparent);
				--globe-border: #1d1d1d;
				--globe-muted: #878179;
				--globe-dim: #555;
			}

			[hidden] { display: none !important; }

			a {
				color: var(--globe-accent);
				text-decoration: none;
			}

			a:hover { text-decoration: underline; }

			button {
				font: inherit;
			}

			.wrap {
				width: min(100%, 900px);
				margin: 0 auto;
				padding: 64px 44px 88px;
			}

			.back-link {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				margin-bottom: 34px;
				color: #666;
				font-size: 11px;
				letter-spacing: 1px;
				text-transform: uppercase;
				transition: color 0.15s;
			}

			.back-link:hover {
				color: #999;
				text-decoration: none;
			}

			.hero {
				max-width: 720px;
				padding-bottom: 42px;
				border-bottom: 1px solid var(--globe-border);
			}

			.project-kicker,
			.section-label,
			.progress-label,
			.event-region {
				color: #4d4d4d;
				font-size: 10px;
				letter-spacing: 4px;
				text-transform: uppercase;
			}

			.project-title {
				margin-top: 18px;
				color: #eae7e0;
				font-size: 72px;
				font-weight: 700;
				letter-spacing: 0;
				line-height: 0.95;
			}

			.project-description {
				max-width: 620px;
				margin-top: 22px;
				color: #9a948b;
				font-size: 15px;
				line-height: 1.75;
			}

			.range-note {
				margin-top: 18px;
				color: #6f6960;
				font-size: 13px;
				line-height: 1.7;
			}

			.action-row {
				display: flex;
				flex-wrap: wrap;
				gap: 12px;
				margin-top: 28px;
			}

			.action-button,
			.answer-button {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-height: 42px;
				border: 1px solid color-mix(in srgb, var(--globe-accent) 46%, #222);
				border-radius: 6px;
				background: var(--globe-accent-soft);
				color: #e8e5dd;
				cursor: pointer;
				font-size: 13px;
				font-weight: 600;
				letter-spacing: 0.2px;
				transition: border-color 0.15s, background 0.15s, transform 0.15s;
			}

			.action-button {
				padding: 0 18px;
			}

			.inline-link {
				display: inline-flex;
				margin-top: 22px;
				color: color-mix(in srgb, var(--globe-accent) 78%, #e2dfd8);
				font-size: 13px;
				font-weight: 600;
			}

			.action-button:hover,
			.answer-button:hover,
			.action-button:focus-visible,
			.answer-button:focus-visible {
				border-color: color-mix(in srgb, var(--globe-accent) 72%, #444);
				background: color-mix(in srgb, var(--globe-accent) 25%, transparent);
				text-decoration: none;
				transform: translateY(-1px);
			}

			.action-button.secondary {
				background: transparent;
				border-color: #2a2a2a;
				color: #9a948b;
			}

			.action-button.copied {
				border-color: color-mix(in srgb, var(--globe-accent) 68%, #222);
				background: color-mix(in srgb, var(--globe-accent) 20%, transparent);
				color: #e8e5dd;
			}

			.range-chip {
				display: inline-flex;
				margin-top: 22px;
				border: 1px solid color-mix(in srgb, var(--globe-accent) 42%, #222);
				border-radius: 999px;
				padding: 8px 12px;
				color: color-mix(in srgb, var(--globe-accent) 76%, #e2dfd8);
				font-size: 12px;
				font-weight: 600;
			}

			.section {
				padding-top: 36px;
			}

			.section-header {
				display: flex;
				align-items: end;
				justify-content: space-between;
				gap: 24px;
				margin-bottom: 22px;
			}

			.section-copy {
				max-width: 520px;
				color: #777;
				font-size: 13px;
				line-height: 1.7;
			}

			.question-shell {
				border-top: 0;
			}

			.question-card {
				padding: 0 0 24px;
				border-bottom: 1px solid var(--globe-border);
			}

			.result-panel {
				display: grid;
				grid-template-columns: minmax(0, 1fr) minmax(300px, 0.9fr);
				gap: 34px;
				padding: 30px 0;
				border-bottom: 1px solid var(--globe-border);
			}

			.question-title,
			.result-title {
				color: #eae7e0;
				font-size: 30px;
				font-weight: 700;
				letter-spacing: 0;
				line-height: 1.15;
			}

			.question-description,
			.result-copy,
			.bound-copy,
			.skipped-copy,
			:global(.bound-copy) {
				margin-top: 14px;
				color: #8d877f;
				font-size: 14px;
				line-height: 1.75;
			}

			.answer-row {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 10px;
				margin-top: 18px;
			}

			.answer-button {
				min-width: 0;
				padding: 0 14px;
			}

			.source-link,
			:global(.source-link) {
				display: inline-flex;
				margin-top: 12px;
				color: color-mix(in srgb, var(--globe-accent) 72%, #666);
				font-size: 11px;
				font-weight: 500;
				text-decoration: none;
			}

			.source-link:hover,
			:global(.source-link:hover) {
				color: var(--globe-accent);
				text-decoration: underline;
			}

			:global(.bound-title) {
				color: #e2dfd8;
				font-size: 15px;
				font-weight: 700;
				line-height: 1.35;
			}

			.share-panel {
				margin-top: 24px;
				border-top: 1px solid var(--globe-border);
				padding-top: 20px;
			}

			.share-label {
				display: block;
				color: #e2dfd8;
				font-size: 13px;
				font-weight: 700;
			}

			.share-row {
				display: flex;
				flex-wrap: wrap;
				gap: 12px;
				margin-top: 10px;
			}

			.share-status {
				min-height: 18px;
				margin-top: 8px;
				color: #6f6960;
				font-size: 12px;
				line-height: 1.5;
			}

			.share-status.copied {
				color: var(--globe-accent);
			}

			.answer-history {
				padding: 30px 0;
				border-bottom: 1px solid var(--globe-border);
			}

			:global(.answer-history-list) {
				display: grid;
				gap: 14px;
				margin-top: 14px;
			}

			:global(.answer-history-item) {
				border: 1px solid #242424;
				border-radius: 6px;
				background: #0f0f0f;
				padding: 14px;
			}

			:global(.answer-history-meta) {
				display: flex;
				flex-wrap: wrap;
				gap: 8px;
				align-items: center;
				color: #666;
				font-size: 11px;
				letter-spacing: 1px;
				text-transform: uppercase;
			}

			:global(.answer-pill) {
				border: 1px solid color-mix(in srgb, var(--globe-accent) 42%, #222);
				border-radius: 999px;
				color: var(--globe-accent);
				padding: 3px 8px;
			}

			:global(.answer-history-question) {
				margin-top: 9px;
				color: #d9d4cb;
				font-size: 13px;
				font-weight: 600;
				line-height: 1.45;
			}

			:global(.answer-history-event) {
				margin-top: 7px;
				color: #777;
				font-size: 12px;
				line-height: 1.5;
			}

			.visual-panel {
				min-height: 340px;
				margin-top: 24px;
				border: 1px solid var(--globe-border);
				border-radius: 6px;
				background:
					radial-gradient(circle at 30% 26%, color-mix(in srgb, var(--globe-accent) 20%, transparent), transparent 34%),
					#101010;
				padding: 20px;
			}

			.visual-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 12px;
				height: 100%;
			}

			.map-state {
				display: flex;
				min-height: 292px;
				flex-direction: column;
				justify-content: space-between;
				border: 1px solid #252525;
				border-radius: 6px;
				background: #0c0c0c;
				padding: 14px;
			}

			.map-state-title {
				color: #e2dfd8;
				font-size: 13px;
				font-weight: 700;
				line-height: 1.25;
			}

			.abstract-map {
				position: relative;
				height: 126px;
				margin: 18px 0;
				border: 1px solid #242424;
				border-radius: 50%;
				background:
					linear-gradient(90deg, transparent 48%, rgba(226, 223, 216, 0.08) 48% 52%, transparent 52%),
					linear-gradient(0deg, transparent 48%, rgba(226, 223, 216, 0.08) 48% 52%, transparent 52%),
					color-mix(in srgb, var(--globe-accent) 10%, #0f0f0f);
				overflow: hidden;
			}

			.abstract-map::before,
			.abstract-map::after {
				content: '';
				position: absolute;
				background: color-mix(in srgb, var(--globe-accent) 34%, #d8d3c9);
				opacity: 0.55;
			}

			.abstract-map::before {
				left: 18%;
				top: 24%;
				width: 34%;
				height: 28%;
				border-radius: 40% 60% 55% 45%;
			}

			.abstract-map::after {
				right: 18%;
				bottom: 24%;
				width: 30%;
				height: 24%;
				border-radius: 55% 45% 42% 58%;
			}

			.map-state.after .abstract-map::before {
				width: 22%;
				transform: translateX(16px);
			}

			.map-state.after .abstract-map::after {
				width: 38%;
				transform: translateX(-12px);
			}

			.map-note {
				color: #777;
				font-size: 12px;
				line-height: 1.55;
			}

			.result-range {
				margin-top: 12px;
				color: var(--globe-accent);
				font-size: 42px;
				font-weight: 700;
				line-height: 1;
			}

			.bound-list {
				display: grid;
				gap: 18px;
				margin-top: 24px;
				border-top: 1px solid var(--globe-border);
				padding-top: 22px;
			}

			.bound-title {
				color: #e2dfd8;
				font-size: 15px;
				font-weight: 700;
				line-height: 1.35;
			}

			.skipped-copy {
				color: #6f6960;
			}

			.timeline,
			.answer-history-list {
				border-top: 1px solid var(--globe-border);
			}

			.timeline-event {
				display: grid;
				grid-template-columns: 110px minmax(0, 1fr);
				gap: 26px;
				padding: 24px 0;
				border-bottom: 1px solid var(--globe-border);
			}

			.timeline-year {
				color: var(--globe-accent);
				font-size: 28px;
				font-weight: 700;
				line-height: 1;
			}

			.timeline-title {
				color: #eae7e0;
				font-size: 19px;
				font-weight: 700;
				line-height: 1.25;
			}

			.timeline-copy {
				margin-top: 8px;
				color: #807970;
				font-size: 13px;
				line-height: 1.7;
			}

			.event-region {
				display: inline-flex;
				margin-bottom: 8px;
				letter-spacing: 2px;
			}

			@media (max-width: 820px) {
				.wrap {
					padding: 44px 24px 68px;
				}

				.question-card,
				.result-panel {
					grid-template-columns: 1fr;
				}

				.project-title {
					font-size: 52px;
				}

			}

			@media (max-width: 560px) {
				.project-title {
					font-size: 42px;
				}

				.section-header {
					display: block;
				}

				.section-copy {
					margin-top: 12px;
				}

				.answer-row,
				.visual-grid {
					grid-template-columns: 1fr;
				}

				.map-state {
					min-height: 220px;
				}

				.timeline-event {
					grid-template-columns: 1fr;
					gap: 10px;
				}

				.result-range {
					font-size: 34px;
				}
			}
		</style>
	</head>
	<body data-min-year={supportedStartYear} data-current-year={currentYear}>
		<main class="wrap" role="main">
			<a href="/" class="back-link" data-umami-event="link_click" data-umami-event-area="navigation" data-umami-event-label="home">&larr; Back to Noah Eisen</a>

			<header class="hero">
				<div>
					<h1 class="project-title">Date My Globe</h1>
					<p class="project-description">
						Answer a short sequence of questions about borders and place names on your globe. The tool narrows the possible date by comparing what you see against a curated timeline of geopolitical changes.
					</p>
					<p class="range-note">
						This version works from 1500 onward, roughly the practical floor for surviving globes. The reference point is the
						<a href="https://en.wikipedia.org/wiki/Behaim_Globe" target="_blank" rel="noopener noreferrer">Behaim Globe</a>,
						created around 1492. The result estimates the globe's map-data date, not necessarily its manufacturing date.
					</p>
					<a class="inline-link" href="/map-my-globe/all-events">View all events &rarr;</a>
				</div>
			</header>

			<section class="section" id="checklist" aria-labelledby="checklist-title">
				<div class="question-shell" id="question-shell" aria-live="polite">
					<div class="question-card" id="question-card">
						<div>
							<h3 class="question-title" id="question-title"></h3>
							<p class="question-description" id="question-description"></p>
							<a class="source-link" id="question-source" target="_blank" rel="noopener noreferrer">Source &rarr;</a>
						</div>

						<div class="visual-panel" aria-label="Placeholder before and after visual">
							<div class="visual-grid">
								<div class="map-state before">
									<div>
										<p class="map-state-title" id="before-label"></p>
										<div class="abstract-map" aria-hidden="true"></div>
									</div>
									<p class="map-note" id="before-note"></p>
								</div>
								<div class="map-state after">
									<div>
										<p class="map-state-title" id="after-label"></p>
										<div class="abstract-map" aria-hidden="true"></div>
									</div>
									<p class="map-note" id="after-note"></p>
								</div>
							</div>
						</div>

						<div class="answer-row" aria-label="Answer the current globe dating question">
							<button class="answer-button" type="button" data-answer="yes">Yes</button>
							<button class="answer-button" type="button" data-answer="no">No</button>
							<button class="answer-button" type="button" data-answer="unsure">Unsure</button>
						</div>
					</div>

					<div class="result-panel" id="result-panel" hidden>
						<div>
							<p class="progress-label">Estimated map-data date</p>
							<h3 class="result-title">Your globe is likely from:</h3>
							<p class="result-range" id="result-range"></p>
							<p class="result-copy" id="result-copy"></p>
							<p class="skipped-copy" id="skipped-copy"></p>
							<div class="share-panel">
								<p class="share-label">Share this checklist</p>
								<div class="share-row">
									<button class="action-button secondary" type="button" id="copy-share-button">Copy link</button>
								</div>
								<p class="share-status" id="share-status">This link opens the completed result and answered clues.</p>
							</div>
							<div class="action-row">
								<a class="inline-link" href="/map-my-globe/all-events">View all events &rarr;</a>
							</div>
						</div>

						<div class="bound-list" aria-label="Bounding events">
							<div id="lower-bound"></div>
							<div id="upper-bound"></div>
						</div>
					</div>

					<div class="answer-history" id="answered-timeline" hidden>
						<div class="section-header">
							<div>
								<span class="section-label">Answered timeline</span>
								<h2 class="question-title">The clues you checked</h2>
							</div>
							<p class="section-copy">
								These are the events used for this result. The full event catalog lives on a separate reference page.
							</p>
						</div>
						<div class="answer-history-list" id="answer-history-list"></div>
						<a class="inline-link" href="/map-my-globe/all-events">View all events &rarr;</a>
					</div>
				</div>
			</section>
		</main>

		<script type="application/json" id="date-my-globe-events" set:html={JSON.stringify(dateMyGlobeEvents)}></script>
		<script>
			const eventsElement = document.getElementById('date-my-globe-events');
			const events = JSON.parse(eventsElement?.textContent || '[]').sort((a, b) => a.year - b.year);
			const minSupportedYear = Number(document.body.dataset.minYear || '1500');
			const currentYear = Number(document.body.dataset.currentYear || String(new Date().getFullYear()));

			const questionCard = document.getElementById('question-card');
			const resultPanel = document.getElementById('result-panel');
			const questionTitle = document.getElementById('question-title');
			const questionDescription = document.getElementById('question-description');
			const questionSource = document.getElementById('question-source');
			const beforeLabel = document.getElementById('before-label');
			const afterLabel = document.getElementById('after-label');
			const beforeNote = document.getElementById('before-note');
			const afterNote = document.getElementById('after-note');
			const resultRange = document.getElementById('result-range');
			const resultCopy = document.getElementById('result-copy');
			const skippedCopy = document.getElementById('skipped-copy');
			const lowerBound = document.getElementById('lower-bound');
			const upperBound = document.getElementById('upper-bound');
			const shareStatus = document.getElementById('share-status');
			const copyShareButton = document.getElementById('copy-share-button');
			const answerHistoryList = document.getElementById('answer-history-list');
			const answeredTimeline = document.getElementById('answered-timeline');

			const answerCodes = {
				yes: 'y',
				no: 'n',
				unsure: 'u',
			};
			const answersByCode = {
				y: 'yes',
				n: 'no',
				u: 'unsure',
			};
			const answerLabels = {
				yes: 'Yes',
				no: 'No',
				unsure: 'Unsure',
			};

			let earliestYear = minSupportedYear;
			let latestYear = currentYear;
			let currentEvent = null;
			let lowerBoundEvent = null;
			let upperBoundEvent = null;
			let askedEventIds = new Set();
			let skippedEvents = [];
			let answerHistory = [];

			function formatRange() {
				return `${earliestYear}-${latestYear >= currentYear ? 'present' : latestYear}`;
			}

			function getCandidates() {
				return events.filter((event) => (
					!askedEventIds.has(event.id) &&
					event.year > earliestYear &&
					event.year <= latestYear
				));
			}

			function getNextEvent() {
				const candidates = getCandidates();
				if (!candidates.length) {
					return null;
				}

				return candidates[Math.floor((candidates.length - 1) / 2)];
			}

			function renderQuestion() {
				currentEvent = getNextEvent();

				if (!currentEvent) {
					renderResult();
					return;
				}

				if (questionTitle) {
					questionTitle.textContent = currentEvent.question;
				}
				if (questionDescription) {
					questionDescription.textContent = currentEvent.description;
				}
				if (questionSource) {
					questionSource.innerHTML = `${currentEvent.sourceLabel} &rarr;`;
					questionSource.setAttribute('href', currentEvent.sourceUrl);
				}
				if (beforeLabel) {
					beforeLabel.textContent = currentEvent.beforeLabel;
				}
				if (afterLabel) {
					afterLabel.textContent = currentEvent.afterLabel;
				}
				if (beforeNote) {
					beforeNote.textContent = currentEvent.visualPlaceholder.beforeNote;
				}
				if (afterNote) {
					afterNote.textContent = currentEvent.visualPlaceholder.afterNote;
				}
			}

			function renderBound(target, heading, event, fallbackCopy) {
				if (!target) {
					return;
				}

				if (!event) {
					target.innerHTML = `
						<h4 class="bound-title">${heading}</h4>
						<p class="bound-copy">${fallbackCopy}</p>
					`;
					return;
				}

				target.innerHTML = `
					<h4 class="bound-title">${heading}: ${event.name} (${event.year})</h4>
					<p class="bound-copy">${event.description}</p>
					<a class="source-link" href="${event.sourceUrl}" target="_blank" rel="noopener noreferrer">${event.sourceLabel} &rarr;</a>
				`;
			}

			function getShareState() {
				return answerHistory
					.map((entry) => `${entry.event.id}:${answerCodes[entry.answer]}`)
					.join(',');
			}

			function getShareUrl() {
				const url = new URL(window.location.href);
				url.searchParams.set('globe', getShareState());
				url.hash = 'checklist';
				return url.toString();
			}

			function renderAnswerHistory() {
				if (!answerHistoryList) {
					return;
				}

				answerHistoryList.replaceChildren();

				answerHistory.forEach((entry, index) => {
					const item = document.createElement('article');
					item.className = 'answer-history-item';

					const meta = document.createElement('div');
					meta.className = 'answer-history-meta';
					meta.textContent = `Question ${index + 1}`;

					const answer = document.createElement('span');
					answer.className = 'answer-pill';
					answer.textContent = answerLabels[entry.answer];
					meta.append(answer);

					const question = document.createElement('p');
					question.className = 'answer-history-question';
					question.textContent = entry.event.question;

					const event = document.createElement('p');
					event.className = 'answer-history-event';
					event.textContent = `${entry.event.name} (${entry.event.year})`;

					item.append(meta, question, event);
					answerHistoryList.append(item);
				});
			}

			function renderResult() {
				if (questionCard) {
					questionCard.hidden = true;
				}
				if (resultPanel) {
					resultPanel.hidden = false;
				}

				if (resultRange) {
					resultRange.textContent = formatRange();
				}
				if (resultCopy) {
					resultCopy.textContent = `This range comes from the clearest confirmed before-and-after clues. It dates the political geography represented on the globe, which can be earlier than the date the object was manufactured.`;
				}
				if (skippedCopy) {
					skippedCopy.textContent = skippedEvents.length
						? `${skippedEvents.length} unsure clue${skippedEvents.length === 1 ? '' : 's'} were skipped, so this range stays wider.`
						: 'No clues were skipped.';
				}

				renderBound(
					lowerBound,
					'Earliest bound',
					lowerBoundEvent,
					`No confirmed lower bound beyond the supported start year of ${minSupportedYear}.`
				);
				renderBound(
					upperBound,
					'Latest bound',
					upperBoundEvent,
					'No confirmed upper bound beyond the current event list.'
				);
				renderAnswerHistory();
				if (copyShareButton) {
					copyShareButton.textContent = 'Copy link';
					copyShareButton.classList.remove('copied');
				}
				if (shareStatus) {
					shareStatus.textContent = 'This link opens the completed result and answered clues.';
					shareStatus.classList.remove('copied');
				}
				if (answeredTimeline) {
					answeredTimeline.hidden = false;
				}
			}

			function applyAnswer(event, answer) {
				if (!event || !answerCodes[answer] || askedEventIds.has(event.id)) {
					return;
				}

				askedEventIds.add(event.id);
				answerHistory.push({ event, answer });

				if (answer === 'yes') {
					earliestYear = Math.max(earliestYear, event.year);
					lowerBoundEvent = event;
				} else if (answer === 'no') {
					latestYear = Math.min(latestYear, event.year - 1);
					upperBoundEvent = event;
				} else {
					skippedEvents.push(event);
				}

				if (latestYear < earliestYear) {
					latestYear = earliestYear;
				}
			}

			function answerQuestion(answer) {
				if (!currentEvent) {
					return;
				}

				applyAnswer(currentEvent, answer);
				renderQuestion();
			}

			function resetChecklistState() {
				earliestYear = minSupportedYear;
				latestYear = currentYear;
				currentEvent = null;
				lowerBoundEvent = null;
				upperBoundEvent = null;
				askedEventIds = new Set();
				skippedEvents = [];
				answerHistory = [];
			}

			function clearSharedUrl() {
				const url = new URL(window.location.href);
				if (!url.searchParams.has('globe')) {
					return;
				}

				url.searchParams.delete('globe');
				history.replaceState(null, '', `${url.pathname}${url.search}${url.hash}`);
			}

			function restartChecklist() {
				resetChecklistState();
				clearSharedUrl();

				if (questionCard) {
					questionCard.hidden = false;
				}
				if (resultPanel) {
					resultPanel.hidden = true;
				}
				if (answeredTimeline) {
					answeredTimeline.hidden = true;
				}
				if (shareStatus) {
					shareStatus.textContent = 'This link opens the completed result and answered clues.';
				}

				renderQuestion();
			}

			function loadSharedChecklist() {
				const sharedState = new URLSearchParams(window.location.search).get('globe');
				if (!sharedState) {
					restartChecklist();
					return;
				}

				resetChecklistState();

				const sharedAnswers = sharedState.split(',').map((entry) => {
					const [eventId, code] = entry.split(':');
					return {
						eventId,
						answer: answersByCode[code],
					};
				});

				for (const sharedAnswer of sharedAnswers) {
					const expectedEvent = getNextEvent();
					if (!expectedEvent || expectedEvent.id !== sharedAnswer.eventId || !sharedAnswer.answer) {
						break;
					}

					applyAnswer(expectedEvent, sharedAnswer.answer);
				}

				if (questionCard) {
					questionCard.hidden = false;
				}
				if (resultPanel) {
					resultPanel.hidden = true;
				}
				if (answeredTimeline) {
					answeredTimeline.hidden = true;
				}
				if (shareStatus) {
					shareStatus.textContent = 'Shared checklist loaded. This link preserves the completed result and answered clues.';
				}

				renderQuestion();
			}

			async function copyText(text) {
				if (window.navigator?.clipboard?.writeText) {
					try {
						await window.navigator.clipboard.writeText(text);
						return true;
					} catch {
						// Fall through to the temporary textarea fallback.
					}
				}

				const textarea = document.createElement('textarea');
				textarea.value = text;
				textarea.setAttribute('readonly', '');
				textarea.style.position = 'fixed';
				textarea.style.top = '-9999px';
				textarea.style.left = '-9999px';
				document.body.append(textarea);
				textarea.select();

				let copied = false;
				try {
					copied = document.execCommand('copy');
				} finally {
					textarea.remove();
				}

				return copied;
			}

			document.querySelectorAll('[data-answer]').forEach((button) => {
				button.addEventListener('click', () => {
					answerQuestion(button.getAttribute('data-answer'));
				});
			});

			copyShareButton?.addEventListener('click', async () => {
				const shareUrl = getShareUrl();

				if (await copyText(shareUrl)) {
					copyShareButton.textContent = 'Copied';
					copyShareButton.classList.add('copied');
					if (shareStatus) {
						shareStatus.textContent = 'Copied. Send it to someone and they will see the same answered checklist.';
						shareStatus.classList.add('copied');
					}
					return;
				}

				if (shareStatus) {
					shareStatus.textContent = 'Copy failed. Try again from the browser address bar.';
					shareStatus.classList.remove('copied');
				}
			});

			loadSharedChecklist();
		</script>
	</body>
</html>
