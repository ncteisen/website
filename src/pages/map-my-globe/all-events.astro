---
import SocialPreview from '../../components/SocialPreview.astro';
import UmamiAnalytics from '../../components/UmamiAnalytics.astro';
import { dateMyGlobeEvents } from '../../data/dateMyGlobeEvents';

const sortedEvents = [...dateMyGlobeEvents].sort((a, b) => a.year - b.year);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Date My Globe Events | Noah Eisen</title>
		<SocialPreview
			title="Noah Eisen - Date My Globe Events"
			description="The geopolitical event list behind Date My Globe."
			path="/map-my-globe/all-events/"
		/>
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300;1,9..40,400&display=swap" rel="stylesheet" />
		<UmamiAnalytics />
		<style>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

			body {
				min-height: 100vh;
				background: #0a0a0a;
				color: #e2dfd8;
				font-family: 'DM Sans', sans-serif;
				-webkit-font-smoothing: antialiased;
				--globe-accent: #83b8a1;
				--globe-border: #1d1d1d;
			}

			a {
				color: var(--globe-accent);
				text-decoration: none;
			}

			a:hover { text-decoration: underline; }

			.wrap {
				width: min(100%, 900px);
				margin: 0 auto;
				padding: 64px 44px 88px;
			}

			.back-link {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				margin-bottom: 34px;
				color: #666;
				font-size: 11px;
				letter-spacing: 1px;
				text-transform: uppercase;
				transition: color 0.15s;
			}

			.back-link:hover {
				color: #999;
				text-decoration: none;
			}

			.header {
				max-width: 680px;
				padding-bottom: 52px;
				border-bottom: 1px solid var(--globe-border);
			}

			.kicker,
			.event-region {
				color: #4d4d4d;
				font-size: 10px;
				letter-spacing: 4px;
				text-transform: uppercase;
			}

			.title {
				margin-top: 18px;
				color: #eae7e0;
				font-size: 58px;
				font-weight: 700;
				letter-spacing: 0;
				line-height: 0.98;
			}

			.description {
				margin-top: 20px;
				color: #9a948b;
				font-size: 15px;
				line-height: 1.75;
			}

			.action-button {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-height: 42px;
				margin-top: 28px;
				border: 1px solid #2a2a2a;
				border-radius: 6px;
				background: transparent;
				color: #9a948b;
				font-size: 13px;
				font-weight: 600;
				padding: 0 18px;
			}

			.action-button:hover {
				border-color: color-mix(in srgb, var(--globe-accent) 55%, #333);
				color: #e2dfd8;
				text-decoration: none;
			}

			.timeline {
				border-top: 1px solid var(--globe-border);
				margin-top: 56px;
			}

			.timeline-event {
				display: grid;
				grid-template-columns: 110px minmax(0, 1fr);
				gap: 26px;
				padding: 24px 0;
				border-bottom: 1px solid var(--globe-border);
			}

			.timeline-year {
				color: var(--globe-accent);
				font-size: 28px;
				font-weight: 700;
				line-height: 1;
			}

			.timeline-title {
				color: #eae7e0;
				font-size: 19px;
				font-weight: 700;
				line-height: 1.25;
			}

			.timeline-copy {
				margin-top: 8px;
				color: #807970;
				font-size: 13px;
				line-height: 1.7;
			}

			.event-region {
				display: inline-flex;
				margin-bottom: 8px;
				letter-spacing: 2px;
			}

			.source-link {
				display: inline-flex;
				margin-top: 14px;
				color: var(--globe-accent);
				font-size: 12px;
				font-weight: 600;
			}

			@media (max-width: 820px) {
				.wrap { padding: 44px 24px 68px; }
				.title { font-size: 44px; }
			}

			@media (max-width: 560px) {
				.timeline-event {
					grid-template-columns: 1fr;
					gap: 10px;
				}
			}
		</style>
	</head>
	<body>
		<main class="wrap" role="main">
			<a href="/projects/date-my-globe" class="back-link">&larr; Back to Date My Globe</a>

			<header class="header">
				<p class="kicker">Reference timeline</p>
				<h1 class="title">All Date My Globe Events</h1>
				<p class="description">
					This is the full event list behind the checklist. It is intentionally curated for clear, visible clues rather than exhaustive world history.
				</p>
				<a class="action-button" href="/projects/date-my-globe">Start checklist</a>
			</header>

			<section class="timeline" aria-label="All Date My Globe events">
				{sortedEvents.map((event) => (
					<article class="timeline-event">
						<div class="timeline-year">{event.year}</div>
						<div>
							<span class="event-region">{event.region}</span>
							<h2 class="timeline-title">{event.name}</h2>
							<p class="timeline-copy">{event.description}</p>
							{event.sourceLabel && event.sourceUrl && (
								<a class="source-link" href={event.sourceUrl} target="_blank" rel="noopener noreferrer">{event.sourceLabel} &rarr;</a>
							)}
						</div>
					</article>
				))}
			</section>
		</main>
	</body>
</html>
